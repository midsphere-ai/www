# Environment template — copy to .env and fill in.
#
# All vars prefixed PUBLIC_ are inlined at build time (Astro/Vite convention)
# and shipped to the browser. Never put secrets in PUBLIC_* keys.
#
# When any of these are unset, the matching SDK is fully tree-shaken from the
# bundle — analytics code costs zero bytes until the key is provided.

# --- Sentry (errors + performance) -------------------------------------------
# Browser DSN. Find it under Settings → Projects → <project> → Client Keys.
PUBLIC_SENTRY_DSN=

# --- PostHog (product analytics) ---------------------------------------------
# Project API key (starts with phc_). Settings → Project → Project API Key.
PUBLIC_POSTHOG_KEY=
# Optional. EU users set https://eu.i.posthog.com.
PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# --- Build SHA --------------------------------------------------------------
# Tags Sentry releases with the deployed commit so a stack trace points at the
# exact build it came from. Populate from CI: `git rev-parse --short HEAD`.
PUBLIC_BUILD_SHA=
