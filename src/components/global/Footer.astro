---
// Inverse-surface footer.
// Brand block + 3 link columns + slim legal row.
type FooterLink = { label: string; href: string };
type FooterColumn = { head: string; links: FooterLink[] };

const footerColumns: FooterColumn[] = [
  { head: 'product',    links: [
    { label: 'Features',      href: '/features' },
    { label: 'Pricing',       href: '/pricing' },
    { label: 'Benchmarks',    href: '/benchmarks' },
    { label: 'Integrations',  href: '/integrations' },
  ]},
  { head: 'compare',    links: [
    { label: 'Cloud-provider agents', href: '/compare/cloud-providers' },
    { label: 'Agent SDKs & frameworks', href: '/compare/agent-frameworks' },
    { label: 'Claude Managed Agents', href: '/compare/claude-managed-agents' },
  ]},
  { head: 'company',    links: [
    { label: 'Blog',          href: '/blog' },
    { label: 'Orbiter',       href: '/orbiter' },
    { label: 'Contact',       href: 'mailto:hello@midsphere.ai' },
  ]},
];
const year = new Date().getFullYear();
---

<footer class="bg-inverse text-on-inverse-1" role="contentinfo">
  <div class="container-x py-20">
    <div class="grid gap-12 pb-12 border-b border-border-on-inverse lg:grid-cols-[1.6fr_repeat(3,1fr)]">
      <div class="relative">
        <a href="/" class="flex items-center" aria-label="Midsphere home">
          <span class="font-mono text-[24px] font-medium leading-none text-on-inverse-1">midsphere</span>
          <span class="ml-1 h-[6px] w-[6px] translate-y-[8px] rounded-full" style="background: var(--ms-accent)" aria-hidden="true"></span>
        </a>
        <p class="mt-4 max-w-[320px] text-[14px]" style="color: var(--ms-fg-on-inverse-2);">
          Built by people who got tired of agent infrastructure.
        </p>

        <!-- Tiny orbit doodle next to brand -->
        <div class="mt-5" aria-hidden="true">
          <svg viewBox="0 0 80 50" width="80" height="50" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" style="opacity: 0.5;">
            <ellipse cx="40" cy="25" rx="34" ry="14" transform="rotate(-12 40 25)"/>
            <circle cx="40" cy="25" r="4"/>
            <circle cx="68" cy="18" r="2"/>
          </svg>
        </div>

        <nav class="mt-6 flex items-center gap-3" aria-label="Social">
          <a href="https://discord.gg/midsphere" target="_blank" rel="noopener noreferrer" class="transition-colors duration-150 hover:opacity-80" style="color: var(--ms-fg-on-inverse-2);" aria-label="Discord">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="9" cy="12" r="1"/><circle cx="15" cy="12" r="1"/>
              <path d="M7.5 7.5c3.5-1 5.5-1 9 0"/><path d="M7 16.5c3.5 1 6.5 1 10 0"/>
              <path d="M15.5 17c.5 1 1.5 2 3 2"/><path d="M5.5 17c.5 1 1.5 2 3 2"/>
              <path d="M8.5 22c1 0 1.5-.5 1.5-1.5V20"/><path d="M15.5 22c-1 0-1.5-.5-1.5-1.5V20"/>
              <path d="M18 18c2-1 3-3 3-5 0-2-1.5-6-1.5-6-1-1-3-1.5-3-1.5L15 7"/>
              <path d="M6 18c-2-1-3-3-3-5 0-2 1.5-6 1.5-6 1-1 3-1.5 3-1.5L9 7"/>
            </svg>
          </a>
          <a href="https://github.com/exo-agi" target="_blank" rel="noopener noreferrer" class="flex items-center gap-1.5 transition-colors duration-150 hover:opacity-80" style="color: var(--ms-fg-on-inverse-2);" aria-label="Exo on GitHub">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/>
              <path d="M9 18c-4.51 2-5-2-7-2"/>
            </svg>
            <span class="font-mono text-[12px]" style="letter-spacing: 0.04em;">Exo</span>
          </a>
        </nav>
      </div>

      {footerColumns.map((column) => (
        <div>
          <div class="eyebrow-on-dark">{column.head}</div>
          <ul class="mt-3.5 flex flex-col gap-2.5">
            {column.links.map((link) => (
              <li><a href={link.href} class="text-[14px] text-on-inverse-1 transition-colors duration-150 hover:opacity-80">{link.label}</a></li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="flex flex-col items-start justify-between gap-3 pt-6 font-mono text-[12px] sm:flex-row sm:items-center" style="color: var(--ms-fg-on-inverse-2);">
      <div>© {year} Midsphere · Open-source MIT</div>
      <div>v1.4.2 · all systems normal</div>
    </div>
  </div>
</footer>
