---
// Closing call-to-action: black panel with lime-highlighted phrase,
// accent CTA + ghost-on-dark secondary. Small inverse rocket doodle
// echoes the hero rocket as a bookend.
import Button from '../ui/Button.astro';
import LightningDoodle from '../ui/LightningDoodle.astro';
---

<section id="ship" class="section">
  <div class="container-x">
    <div class="rounded-[28px] bg-inverse px-12 py-[72px] text-center text-on-inverse-1">
      <div class="mx-auto mb-4 flex justify-center">
        <LightningDoodle variant="on-dark" width={120} />
      </div>
      <div class="eyebrow-on-dark">ship</div>
      <h2
        id="ship-headline"
        class="h-display-lg mx-auto mt-4 mb-5 max-w-[820px] text-on-inverse-1"
      >
        The hard part is built.<br /><span class="hl text-on-inverse-1">Go ship the feature</span>.
      </h2>
      <p class="mx-auto mb-8 max-w-[560px] text-[16px] leading-[1.55]" style="color: var(--ms-fg-on-inverse-2);">
        Most builders have something running the same afternoon they sign up. The integration is three lines. The longest part is deciding what to ship first.
      </p>
      <div class="flex flex-wrap justify-center gap-2.5">
        <Button href="https://platform.midsphere.ai" variant="accent">Start building</Button>
        <Button href="/orbiter" variant="ghost-on-dark">Read the docs</Button>
      </div>
    </div>
  </div>
</section>
