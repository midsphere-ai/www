---
// "You built it before lunch."
// Stepped morning-to-afternoon narrative. The middle cell is a notification
// from a previously-shipped product's analytics agent — surfacing an insight
// in parallel with today's build.
type SimpleStep = { kind?: 'simple'; n: string; text: string };
type InsightStep = {
  kind: 'insight';
  n: string;
  source: string;
  headline: string;
  body: string;
  hint: string;
};
type DayStep = SimpleStep | InsightStep;

const dayInLifeSteps: DayStep[] = [
  { n: '09:14', text: 'Sketch it on the back of something.' },
  {
    kind: 'insight',
    n: '11:02',
    source: 'analytics agent',
    headline: 'Your analytics agent noticed something.',
    body: "47 of your users tried to attach files this week. Your agent could handle them — you just don't surface the capability in your UI.",
    hint: 'Here are the user IDs and conversations.',
  },
  { n: '14:20', text: 'Ship to production.' },
];
---

<section id="today" class="section">
  <div class="container-x">
    <!-- Anchor doodle: sunrise → coffee → ship timeline -->
    <div class="mx-auto mb-6 flex justify-center" aria-hidden="true">
      <svg viewBox="0 0 320 60" width="280" height="52" fill="none" stroke="#111" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
        <!-- sun rising -->
        <path d="M14 44 L 56 44"/>
        <path d="M22 44 C 22 32, 30 24, 35 24 C 40 24, 48 32, 48 44"/>
        <path d="M14 16 L 18 12 M 56 16 L 52 12 M 35 12 L 35 6"/>
        <!-- timeline line -->
        <path d="M64 30 L 124 30" stroke-dasharray="3 4"/>
        <!-- coffee cup -->
        <path d="M132 22 L 168 22 L 166 44 C 166 48, 162 50, 158 50 L 142 50 C 138 50, 134 48, 134 44 Z"/>
        <path d="M168 26 C 176 26, 176 38, 168 38"/>
        <path d="M142 16 C 142 12, 144 10, 146 12 M 152 16 C 152 12, 154 10, 156 12"/>
        <!-- timeline line -->
        <path d="M180 30 L 240 30" stroke-dasharray="3 4"/>
        <!-- ship -->
        <path d="M256 44 L 304 44 L 300 50 L 260 50 Z"/>
        <path d="M280 16 L 280 44"/>
        <path d="M280 18 L 300 30 L 280 32"/>
        <path d="M280 20 L 264 30 L 280 32"/>
      </svg>
    </div>

    <div class="mb-10 text-center">
      <div class="eyebrow">today</div>
      <h2 id="today-headline" class="h-section mx-auto mt-3 max-w-[860px]">
        You built it before lunch. <span class="hl">Your competitors are still in their planning meeting.</span>
      </h2>
    </div>

    <ol class="mx-auto grid max-w-[900px] grid-cols-1 items-start gap-4 md:grid-cols-3 md:gap-5">
      {dayInLifeSteps.map((step) => (
        step.kind === 'insight' ? (
          <li class="rounded-[12px] border border-border-subtle bg-canvas p-5">
            <div class="flex items-center gap-2">
              <span class="font-mono text-[12px]" style="color: var(--ms-fg-3); letter-spacing: 0.06em;">{step.n}</span>
              <span aria-hidden="true" class="inline-block h-1.5 w-1.5 rounded-full" style="background: var(--ms-accent);"></span>
              <span class="font-mono text-[12px]" style="color: var(--ms-fg-3); letter-spacing: 0.06em;">{step.source}</span>
            </div>
            <p class="mt-3 font-medium text-fg-1" style="font-size: 16px; line-height: 1.4;">{step.headline}</p>
            <p class="mt-2 text-fg-2" style="font-size: 14px; line-height: 1.55;">{step.body}</p>
            <p class="mt-3 inline-flex items-center gap-1.5 font-mono text-[12px]" style="color: var(--ms-fg-2); letter-spacing: 0.04em;">
              <svg width="12" height="10" viewBox="0 0 14 10" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M1 5 L 12 5"/>
                <path d="M8.5 1.5 L 12 5 L 8.5 8.5"/>
              </svg>
              {step.hint}
            </p>
          </li>
        ) : (
          <li class="rounded-[12px] border border-border-subtle bg-canvas p-5">
            <div class="font-mono text-[12px]" style="color: var(--ms-fg-3); letter-spacing: 0.06em;">{step.n}</div>
            <p class="mt-2 font-medium text-fg-1" style="font-size: 16px; line-height: 1.4;">{step.text}</p>
          </li>
        )
      ))}
    </ol>

    <div class="mx-auto mt-12 max-w-[640px] text-center">
      <p class="text-fg-2" style="font-size: 17px; line-height: 1.6;">
        You don't read a single paper. You don't pick a model. You don't hire someone with "ML" in their title. You don't build the thing the agent runs on — that's our problem.
      </p>
      <p class="mt-4 text-fg-2" style="font-size: 17px; line-height: 1.6;">
        Ship to one user. Then ten. Then ten thousand. Same setup, no rewrites.
      </p>
      <p class="mt-4 text-fg-2" style="font-size: 17px; line-height: 1.6;">
        And nobody's getting paged at <span class="inline-flex items-baseline gap-1">3am
          <svg width="18" height="14" viewBox="0 0 24 18" fill="none" stroke="#111" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" style="opacity: 0.6;" aria-hidden="true">
            <path d="M2 14 L 14 14 L 2 4 L 14 4"/>
            <path d="M11 8 L 18 8 L 11 2 L 18 2"/>
          </svg></span>.
      </p>
    </div>
  </div>
</section>
