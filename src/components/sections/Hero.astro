---
import Button from '../ui/Button.astro';
import CodeBlock from '../ui/CodeBlock.astro';
import PencilDoodle from '../ui/PencilDoodle.astro';
import MarginAnnotation from '../ui/MarginAnnotation.astro';

const heroCode = `from midsphere import Agent

agent = Agent(tools=user.connected_apps, knowledge=user.history)
agent.run("Plan the user's day from their inbox")`;
---

<section id="hero" class="pt-12 pb-16 text-center lg:pt-16 lg:pb-20">
  <div class="container-x">
    <div class="mx-auto flex justify-center doodle-float" aria-hidden="true">
      <PencilDoodle width={150} />
    </div>

    <h1
      id="hero-headline"
      class="h-display mx-auto mt-5 max-w-[880px] text-fg-1"
    ><span class="hero-line">Ship the AI feature </span><span class="hero-line hero-line-rotator"><span class="rotating-phrase" aria-live="polite"><span class="hl rotating-ghost" aria-hidden="true"></span><span class="rotating-stack"><span class="hl rotating-item">you sketched this morning</span></span></span> </span><span class="hero-line">in an afternoon.</span></h1>

    <!-- Morning → afternoon sun-arc: the headline's time claim, made visual.
         Two suns book-end an arc, one rising, one settling. -->
    <div class="mx-auto mt-5 flex justify-center" aria-hidden="true">
      <svg viewBox="0 0 112 36" width="100" height="32" fill="none" stroke="#111" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
        <path d="M4 28 L 108 28" stroke-dasharray="2 3" style="opacity: 0.45;"/>
        <circle cx="14" cy="28" r="4.5"/>
        <path d="M14 21 L 14 17 M 6 28 L 2 28 M 8.5 23 L 5.5 20"/>
        <path d="M16 26 C 30 6, 82 6, 96 26" stroke-dasharray="3 3"/>
        <circle cx="98" cy="28" r="4.5"/>
        <path d="M98 21 L 98 17 M 106 28 L 110 28 M 103 23 L 106 20"/>
      </svg>
    </div>

    <p
      class="mx-auto mt-5 max-w-[680px] text-fg-2"
      style="font-size: 18px; line-height: 1.55; text-wrap: pretty;"
    >
      The autonomous agent you'd spend three months building. In <span class="hl-soft">three lines of code</span>.
    </p>

    <div class="relative mx-auto mt-9 max-w-[640px] text-left">
      <CodeBlock code={heroCode} />

      <MarginAnnotation
        text="user's apps · not your code."
        position="left"
        topOffset="56px"
      />
      <MarginAnnotation
        text="no init. no auth dance."
        position="right"
        topOffset="22px"
      />
    </div>

    <div class="mt-9 flex flex-wrap justify-center gap-2.5">
      <Button href="https://platform.midsphere.ai" variant="primary">Start building</Button>
      <Button href="/orbiter" variant="secondary">Read the docs</Button>
    </div>

    <!-- Closing flourish: hand-drawn check + small caption.
         Punctuates the hero — what you'd write at the end of a sketchbook page. -->
    <div class="mt-6 flex items-center justify-center gap-2" style="opacity: 0.7;">
      <svg width="18" height="14" viewBox="0 0 20 16" fill="none" stroke="#111" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M2 9 L 8 14 L 18 2"/>
      </svg>
      <span class="font-mono" style="font-size: 11px; letter-spacing: 0.06em; color: var(--ms-fg-2);">
        free credits · no card · no setup file
      </span>
    </div>
  </div>
</section>

<script>
  import { initRotatingPhrase } from '../../scripts/rotatingPhrase';

  const variants = [
    'you sketched this morning',
    'you owe your team',
    'users keep asking for',
    "your competitors haven't",
  ];

  const start = () => initRotatingPhrase({ rootSelector: '#hero', variants });
  let dispose: (() => void) | null = start();
  document.addEventListener('astro:before-swap', () => { dispose?.(); dispose = null; });
  document.addEventListener('astro:after-swap', () => { dispose = start(); });
</script>
