---
// Pain + mental model.
// The mental-model unit is wrapped in a sunken card so it reads as one block.
// Two character doodles carry the contrast:
//   chatbot — a face stuck in a chat window with a "?" floating
//   agent  — a stick figure walking off with a clipboard, "on it" overhead
// Personality, not abstraction. The teammate paragraph beneath grounds it.
---

<section id="premise" class="section">
  <div class="container-x">
    <!-- 1. Pain — centered -->
    <div class="mx-auto max-w-[760px] text-center">
      <div class="eyebrow">what this is</div>
      <h2 id="premise-headline" class="h-section mx-auto mt-3 max-w-[680px]">
        There's a feature you keep <span class="hl">putting off</span>.
      </h2>
      <p class="mx-auto mt-5 max-w-[600px] text-fg-2" style="font-size: 17px; line-height: 1.6;">
        The user types what they want. The product just does it. You've sketched it. You've punted on it twice. Six months of agent infrastructure stands between you and the feature itself.
      </p>
    </div>

    <!-- 2. Mental model — tight cluster on canvas -->
    <div class="mx-auto mt-12 max-w-[920px]">
      <h3
        id="agent-vs-chatbot"
        class="text-center font-medium text-fg-2"
        style="font-size: 18px; line-height: 1.3; letter-spacing: -0.005em;"
      >
        Because an agent isn't a chatbot.
      </h3>

      <div class="mt-8 grid grid-cols-1 items-end gap-8 md:grid-cols-2 md:gap-12">
        <!-- LEFT: chatbot — a face stuck inside a chat window -->
        <div class="text-center">
          <svg viewBox="0 0 200 180" width="180" height="162" fill="none" stroke="#111" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="mx-auto">
            <!-- chat window (with tail) -->
            <path d="M28 38 L 156 36 C 162 36, 166 40, 166 46 L 168 122 C 168 128, 164 132, 158 132 L 100 134 L 86 150 L 88 134 L 30 136 C 24 136, 20 132, 20 126 L 18 48 C 18 42, 22 38, 28 38 Z"/>
            <!-- face inside -->
            <circle cx="92" cy="86" r="24"/>
            <!-- eyes (just dots, blank stare) -->
            <circle cx="83" cy="82" r="2" fill="#111"/>
            <circle cx="101" cy="82" r="2" fill="#111"/>
            <!-- flat mouth (no expression) -->
            <path d="M83 100 L 101 100"/>
            <!-- hand-drawn "?" (path, not text) -->
            <path d="M138 56 C 138 48, 146 44, 152 48 C 158 52, 158 60, 152 62 C 146 64, 146 70, 146 74" stroke-width="1.4"/>
            <circle cx="146" cy="80" r="1.8" fill="#111"/>
          </svg>
          <div class="eyebrow mt-4">chatbot</div>
          <p class="mt-2 mx-auto max-w-[260px] font-medium text-fg-1" style="font-size: 16px; line-height: 1.4;">
            Polite. Limited. Sleeps between turns.
          </p>
        </div>

        <!-- RIGHT: agent — striding figure with clipboard, "on it" overhead -->
        <div class="text-center">
          <svg viewBox="0 0 240 180" width="200" height="150" fill="none" stroke="#111" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="mx-auto">
            <!-- speech bubble (top-right) -->
            <path d="M132 18 L 218 16 C 224 16, 228 20, 228 26 L 230 50 C 230 56, 226 60, 220 60 L 174 62 L 166 74 L 168 62 L 134 64 C 128 64, 124 60, 124 54 L 122 28 C 122 22, 126 18, 132 18 Z"/>
            <!-- speech lines (suggesting words, not actual text) -->
            <path d="M140 32 L 174 32" stroke-width="1.4"/>
            <path d="M140 42 L 198 42" stroke-width="1.4"/>
            <path d="M140 52 L 184 52" stroke-width="1.4"/>
            <!-- character: head -->
            <circle cx="62" cy="62" r="12"/>
            <!-- body, slight forward lean -->
            <path d="M62 74 L 56 118"/>
            <!-- legs mid-stride -->
            <path d="M56 118 L 36 156 M 56 118 L 78 158"/>
            <!-- arm extending to clipboard -->
            <path d="M58 86 L 86 100"/>
            <!-- clipboard -->
            <path d="M86 84 L 122 86 L 124 138 L 86 138 Z"/>
            <path d="M98 84 L 98 78 L 114 78 L 114 86"/>
            <path d="M92 100 L 118 102 M 92 110 L 116 112 M 92 120 L 110 122"/>
            <!-- motion lines on the ground -->
            <path d="M14 168 L 32 168 M 90 168 L 122 168" stroke-dasharray="2 4"/>
          </svg>
          <div class="eyebrow mt-4">agent</div>
          <p class="mt-2 mx-auto max-w-[260px] font-medium text-fg-1" style="font-size: 16px; line-height: 1.4;">
            Brief it. Walk away. <span class="hl-soft">Comes back done.</span>
          </p>
        </div>
      </div>

    </div>

    <!-- 3. Closing pull-quote -->
    <div class="mx-auto mt-16 max-w-[820px] text-center">
      <p class="font-medium text-fg-1" style="font-size: clamp(24px, 2.6vw, 30px); line-height: 1.25; letter-spacing: -0.02em; text-wrap: balance;">
        We did the six-month detour. <span class="hl">You go build the feature.</span>
      </p>
    </div>
  </div>
</section>
