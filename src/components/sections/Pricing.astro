---
// Pricing tease — the bill itself is the metaphor. A single sketched receipt
// does the work the four-tile grid used to do: what you pay for, what you'd
// expect to pay for but don't, the cap. Below the perforated tear, your
// weekend.
import Button from '../ui/Button.astro';
import Receipt from './Receipt.astro';

type LineItem = { label: string; amount: string };

const charged: LineItem[] = [
  { label: 'free credits on signup', amount: '$0' },
  { label: 'top-ups (any amount)', amount: 'your call' },
  { label: 'agent runs (the work)', amount: 'per use' },
];

const struckThrough: LineItem[] = [
  { label: 'per seat', amount: '—' },
  { label: 'per minute', amount: '—' },
  { label: 'monthly subscription', amount: '—' },
  { label: 'expiring credits', amount: '—' },
];
---

<section id="pricing" class="section border-b border-border-subtle">
  <div class="container-x">
    <div class="mx-auto mb-5 flex justify-center" aria-hidden="true">
      <svg viewBox="0 0 80 60" width="68" height="52" fill="none" stroke="#111" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
        <rect x="6" y="14" width="68" height="34" rx="4"/>
        <path d="M6 24 L 74 24"/>
        <path d="M14 36 L 28 36 M 14 42 L 22 42"/>
        <path d="M2 50 L 78 12" stroke="#111" stroke-width="1.8" />
      </svg>
    </div>

    <div class="mb-12 text-center">
      <div class="eyebrow">the bill</div>
      <h2 id="pricing-headline" class="h-section mx-auto mt-3 max-w-[760px]">
        Pricing that respects <span class="hl-soft">your weekend</span>.
      </h2>
    </div>

    <Receipt charged={charged} struckThrough={struckThrough} />

    <p
      class="mx-auto mt-4 text-center font-mono"
      style="max-width: 460px; font-size: 11px; color: var(--ms-fg-3); letter-spacing: 0.08em; text-transform: lowercase;"
    >
      <svg width="14" height="10" viewBox="0 0 18 12" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="display: inline-block; vertical-align: -1px; margin-right: 6px; opacity: 0.65;">
        <circle cx="3" cy="3" r="2"/>
        <circle cx="3" cy="9" r="2"/>
        <path d="M5 4 L 17 9 M 5 8 L 17 3"/>
      </svg>
      tear here · the rest of the day is yours
    </p>

    <p
      class="mx-auto mt-12 max-w-[760px] text-center font-medium text-fg-1"
      style="font-size: clamp(20px, 2.2vw, 26px); line-height: 1.3; letter-spacing: -0.02em; text-wrap: balance;"
    >
      No card up front. <span class="hl">No surprise at the end of the month.</span>
    </p>

    <div class="mt-8 flex justify-center">
      <Button href="/pricing" variant="secondary">See full pricing</Button>
    </div>
  </div>
</section>
