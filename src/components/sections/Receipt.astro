---
// Hand-laid receipt for the homepage Pricing tease. Two columns of mono with
// a perforated tear at the bottom and a margin annotation.
import MarginAnnotation from '../ui/MarginAnnotation.astro';

type LineItem = { label: string; amount: string };

interface Props {
  charged: LineItem[];
  struckThrough: LineItem[];
}

const { charged, struckThrough } = Astro.props;

const wavyDivider = `M2 3 Q 12 0, 22 3 T 42 3 T 62 3 T 82 3 T 102 3 T 122 3 T 142 3 T 162 3 T 182 3 T 202 3 T 222 3 T 242 3 T 262 3 T 282 3 T 302 3 T 322 3 T 342 3 T 362 3 T 382 3 T 398 3`;
---

<div class="relative mx-auto" style="max-width: 460px;">
  <div
    class="bg-canvas"
    style="border: 1px solid var(--ms-border-default); border-bottom: none; padding: 32px 36px 24px; transform: rotate(-0.4deg); box-shadow: 0 1px 0 rgba(0,0,0,0.04), 0 8px 24px -16px rgba(0,0,0,0.12);"
  >
    <div class="text-center" style="margin-bottom: 20px;">
      <div class="font-mono" style="font-size: 11px; letter-spacing: 0.22em; color: var(--ms-fg-2); text-transform: uppercase;">midsphere · your bill</div>
    </div>

    <div aria-hidden="true" style="margin: 0 -4px 14px;">
      <svg viewBox="0 0 400 6" width="100%" height="6" preserveAspectRatio="none" fill="none" stroke="#111" stroke-width="1" stroke-linecap="round" style="opacity: 0.45;">
        <path d={wavyDivider}/>
      </svg>
    </div>

    <ul class="font-mono" style="font-size: 14px; color: var(--ms-fg-1);">
      {charged.map((item) => (
        <li class="flex items-baseline justify-between gap-4" style="padding: 7px 0;">
          <span>{item.label}</span>
          <span style="font-variant-numeric: tabular-nums;">{item.amount}</span>
        </li>
      ))}
    </ul>

    <div aria-hidden="true" style="margin: 14px -4px;">
      <svg viewBox="0 0 400 6" width="100%" height="6" preserveAspectRatio="none" fill="none" stroke="#111" stroke-width="1" stroke-linecap="round" style="opacity: 0.45;">
        <path d={wavyDivider}/>
      </svg>
    </div>

    <div class="font-mono" style="font-size: 11px; letter-spacing: 0.06em; color: var(--ms-fg-3); text-transform: lowercase;">not on this bill</div>

    <ul class="font-mono" style="font-size: 14px; color: var(--ms-fg-3); margin-top: 4px;">
      {struckThrough.map((item) => (
        <li class="flex items-baseline justify-between gap-4" style="padding: 5px 0; text-decoration: line-through; text-decoration-thickness: 1px;">
          <span>{item.label}</span>
          <span style="font-variant-numeric: tabular-nums;">{item.amount}</span>
        </li>
      ))}
    </ul>

    <div aria-hidden="true" style="margin: 16px -4px 12px;">
      <svg viewBox="0 0 400 6" width="100%" height="6" preserveAspectRatio="none" fill="none" stroke="#111" stroke-width="1" stroke-linecap="round" style="opacity: 0.45;">
        <path d={wavyDivider}/>
      </svg>
    </div>

    <div class="flex items-baseline justify-between gap-4 font-mono" style="font-size: 14px; color: var(--ms-fg-1);">
      <span style="font-weight: 500;">total</span>
      <span style="font-weight: 500;">≤ <span class="hl-soft">what you set</span></span>
    </div>
    <p class="font-mono" style="font-size: 11px; color: var(--ms-fg-2); margin-top: 10px; text-align: center; letter-spacing: 0.04em;">
      <svg width="16" height="12" viewBox="0 0 18 14" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="display: inline-block; vertical-align: -1px; margin-right: 6px; opacity: 0.65;">
        <path d="M2 4 L 16 4"/>
        <path d="M9 13 L 9 6"/>
        <path d="M6 9 L 9 6 L 12 9"/>
      </svg>past it, the agent stops · nobody pages you
    </p>
  </div>

  <svg
    viewBox="0 0 460 18"
    width="100%"
    height="18"
    fill="none"
    stroke="#111"
    stroke-width="1.4"
    stroke-linecap="round"
    stroke-linejoin="round"
    preserveAspectRatio="none"
    aria-hidden="true"
    style="display: block; transform: rotate(-0.4deg); transform-origin: center top;"
  >
    <path d="M0 9 L 14 16 L 28 4 L 42 16 L 56 4 L 70 16 L 84 4 L 98 16 L 112 4 L 126 16 L 140 4 L 154 16 L 168 4 L 182 16 L 196 4 L 210 16 L 224 4 L 238 16 L 252 4 L 266 16 L 280 4 L 294 16 L 308 4 L 322 16 L 336 4 L 350 16 L 364 4 L 378 16 L 392 4 L 406 16 L 420 4 L 434 16 L 448 4 L 460 9"/>
  </svg>

  <MarginAnnotation
    text="things you'd expect on a SaaS bill — left off on purpose"
    position="right"
    tilt={-2.4}
    topOffset="252px"
    width="180px"
  />
</div>
