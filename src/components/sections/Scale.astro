---
// "Build for one. Ship for everyone."
// Same shape, optional policies layered on as needed.
import ScaleSliderDoodle from './ScaleSliderDoodle.astro';

type Policy = { name: string; gist: string };

const policies: Policy[] = [
  { name: 'spend caps',         gist: "set a number. a runaway loop can't go past it." },
  { name: 'approval gates',     gist: "anything irreversible — sending email, charging cards — waits for a human." },
  { name: 'per-user isolation', gist: "the agent for user A never sees user B's anything." },
  { name: 'allowed tools',      gist: 'ship with a short list. expand it as your trust grows.' },
];
---

<section id="scale" class="section border-t border-border-subtle">
  <div class="container-x">
    <div class="grid grid-cols-1 items-start gap-10 md:grid-cols-[1fr_280px] md:gap-14">
      <div>
        <div class="eyebrow">scale</div>
        <h2 id="scale-headline" class="h-section mt-3 max-w-[640px]">
          Build for one. <span class="hl">Ship for everyone.</span>
        </h2>
        <p class="mt-5 max-w-[640px] text-fg-2" style="font-size: 17px; line-height: 1.6;">
          A weekend prototype runs the agent once. A production app runs it a million times. Nothing about your code changes — the call stays the call.
        </p>
        <p class="mt-4 max-w-[640px] text-fg-2" style="font-size: 17px; line-height: 1.6;">
          What you add are guard rails. Same agent, just on a leash.
        </p>
      </div>

      <!-- Doodle: one dot becoming many -->
      <div class="hidden md:flex md:items-center md:justify-center" aria-hidden="true">
        <svg viewBox="0 0 280 80" width="280" height="80" fill="none" stroke="#111" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="20" cy="40" r="6"/>
          <path d="M34 40 C 50 38, 56 42, 70 40"/>
          <path d="M64 36 L 72 40 L 64 44"/>
          <circle cx="92" cy="40" r="3.5"/>
          <circle cx="106" cy="32" r="3.5"/>
          <circle cx="106" cy="48" r="3.5"/>
          <circle cx="120" cy="40" r="3.2"/>
          <circle cx="134" cy="28" r="3"/>
          <circle cx="134" cy="40" r="3"/>
          <circle cx="134" cy="52" r="3"/>
          <circle cx="148" cy="22" r="2.8"/>
          <circle cx="148" cy="34" r="2.8"/>
          <circle cx="148" cy="46" r="2.8"/>
          <circle cx="148" cy="58" r="2.8"/>
          <circle cx="162" cy="28" r="2.6"/>
          <circle cx="162" cy="40" r="2.6"/>
          <circle cx="162" cy="52" r="2.6"/>
          <circle cx="176" cy="22" r="2.4"/>
          <circle cx="176" cy="34" r="2.4"/>
          <circle cx="176" cy="46" r="2.4"/>
          <circle cx="176" cy="58" r="2.4"/>
          <circle cx="190" cy="28" r="2.2"/>
          <circle cx="190" cy="40" r="2.2"/>
          <circle cx="190" cy="52" r="2.2"/>
          <circle cx="204" cy="22" r="2"/>
          <circle cx="204" cy="34" r="2"/>
          <circle cx="204" cy="46" r="2"/>
          <circle cx="204" cy="58" r="2"/>
          <circle cx="218" cy="28" r="2"/>
          <circle cx="218" cy="40" r="2"/>
          <circle cx="218" cy="52" r="2"/>
          <circle cx="232" cy="22" r="1.8"/>
          <circle cx="232" cy="34" r="1.8"/>
          <circle cx="232" cy="46" r="1.8"/>
          <circle cx="232" cy="58" r="1.8"/>
          <circle cx="246" cy="28" r="1.6"/>
          <circle cx="246" cy="40" r="1.6"/>
          <circle cx="246" cy="52" r="1.6"/>
          <circle cx="260" cy="34" r="1.4"/>
          <circle cx="260" cy="46" r="1.4"/>
          <circle cx="270" cy="40" r="1.2"/>
        </svg>
      </div>
    </div>

    <!-- Anchor doodle: a path running between two fences.
         The fences are the policies; the arrow is the agent's run.
         Reads as "stay on the road" — same agent, just on a leash. -->
    <div class="mx-auto mt-12 flex justify-center" aria-hidden="true">
      <svg viewBox="0 0 260 56" width="200" height="44" fill="none" stroke="#111" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
        <path d="M10 22 C 30 21, 60 23, 90 22"/>
        <path d="M10 32 C 30 31, 60 33, 90 32"/>
        <path d="M18 16 L 18 42"/>
        <path d="M46 17 L 46 42"/>
        <path d="M74 16 L 74 42"/>
        <path d="M104 28 L 152 28" stroke-width="1.4"/>
        <path d="M146 23 L 152 28 L 146 33" stroke-width="1.4"/>
        <path d="M170 22 C 190 21, 220 23, 250 22"/>
        <path d="M170 32 C 190 31, 220 33, 250 32"/>
        <path d="M186 16 L 186 42"/>
        <path d="M214 17 L 214 42"/>
        <path d="M242 16 L 242 42"/>
        <path d="M4 48 L 256 48" stroke-dasharray="2 4" stroke-width="1.2" style="opacity: 0.45;"/>
      </svg>
    </div>

    <div class="mx-auto mt-4 max-w-[820px] rounded-[14px] border border-border-subtle bg-canvas p-7 sm:p-9">
      <div class="eyebrow">add when you need</div>
      <ul class="mt-5 grid grid-cols-1 gap-4 sm:grid-cols-2 sm:gap-x-10 sm:gap-y-5">
        {policies.map((policy) => (
          <li class="flex items-baseline gap-3">
            <span aria-hidden="true" class="font-mono" style="color: var(--ms-fg-3); font-size: 14px;">+</span>
            <div class="min-w-0">
              <div class="font-mono text-fg-1" style="font-size: 13px; letter-spacing: 0.02em;">{policy.name}</div>
              <p class="mt-1 text-fg-2" style="font-size: 14px; line-height: 1.5;">{policy.gist}</p>
            </div>
          </li>
        ))}
      </ul>
    </div>

    <ScaleSliderDoodle />
  </div>
</section>
