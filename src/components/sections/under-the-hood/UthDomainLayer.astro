---
import CodeBlock from '../../ui/CodeBlock.astro';
import YoursPillarDoodle from '../../ui/YoursPillarDoodle.astro';

const domainCode = `from midsphere import Agent

agent = Agent(
  tools=[search_tickets, send_email, *mcp_servers],
  skills="./skills",       # markdown runbooks
  knowledge=user.history,  # embedded; pulled in as relevant
)

agent.run("Triage this week's incidents and draft the postmortem")`;
---

<section id="domain" class="section border-t border-border-subtle">
  <div class="container-x">
    <div class="mx-auto max-w-[600px] text-center">
      <div class="eyebrow">wiring it up</div>
      <h2 id="domain-headline" class="h-section mt-3">
        Three slots. Yours to fill.
      </h2>
      <p class="mx-auto mt-5 max-w-[520px] text-fg-2" style="font-size: 17px; line-height: 1.6;">
        The architecture above is generic. The domain layer is what turns the same engine into a triager, a research bot, or a workflow runner.
      </p>
    </div>

    <div class="mx-auto mt-10 grid max-w-[1080px] grid-cols-1 gap-5 md:grid-cols-3 md:gap-6">
      <article class="rounded-[12px] border border-border-subtle bg-canvas p-7">
        <div class="mb-4">
          <YoursPillarDoodle kind="tools" />
        </div>
        <div class="eyebrow">tools</div>
        <h3 id="domain-tools" class="mt-2 font-medium text-fg-1" style="font-size: 18px; letter-spacing: -0.015em;">
          What it can call.
        </h3>
        <p class="mt-3 text-fg-2" style="font-size: 15px; line-height: 1.6;">
          Filesystem, shell, browser, search — out of the box. MCP-style for everything else: your DB, your APIs, the user’s OAuth accounts.
        </p>
      </article>

      <article class="rounded-[12px] border border-border-subtle bg-canvas p-7">
        <div class="mb-4">
          <YoursPillarDoodle kind="skills" />
        </div>
        <div class="eyebrow">skills</div>
        <h3 id="domain-skills" class="mt-2 font-medium text-fg-1" style="font-size: 18px; letter-spacing: -0.015em;">
          How your team does the job.
        </h3>
        <p class="mt-3 text-fg-2" style="font-size: 15px; line-height: 1.6;">
          Markdown runbooks. We ship defaults for research, summarisation, code, and drafting. Override or extend per agent.
        </p>
      </article>

      <article class="rounded-[12px] border border-border-subtle bg-canvas p-7">
        <div class="mb-4">
          <YoursPillarDoodle kind="knowledge" />
        </div>
        <div class="eyebrow">knowledge</div>
        <h3 id="domain-knowledge" class="mt-2 font-medium text-fg-1" style="font-size: 18px; letter-spacing: -0.015em;">
          What it reads first.
        </h3>
        <p class="mt-3 text-fg-2" style="font-size: 15px; line-height: 1.6;">
          Product docs, the user’s history, the last five tickets they filed — embedded once, retrieved when relevant.
        </p>
      </article>
    </div>

    <div class="mx-auto mt-10 max-w-[680px]">
      <CodeBlock code={domainCode} />
    </div>
  </div>
</section>
