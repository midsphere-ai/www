---
const specs = [
  { spec: 'cold start',      val: '< 5s' },
  { spec: 'snapshot resume', val: '< 500ms' },
  { spec: 'idle',            val: 'scales to zero' },
];
---

<section id="sandboxing" class="section">
  <div class="container-x">
    <div class="grid grid-cols-1 items-start gap-10 md:grid-cols-[1fr_220px] md:gap-14">
      <div>
        <div class="eyebrow">where it runs</div>
        <h2 id="sandboxing-headline" class="h-section mt-3 max-w-[520px]">
          Each run gets its own <span class="hl-soft">Firecracker microVM</span>.
        </h2>
        <p class="mt-5 max-w-[520px] text-fg-2" style="font-size: 17px; line-height: 1.65;">
          Same isolation model AWS Lambda runs on. Containers don’t give you real hardware-level separation between tenants; V8 isolates can’t host the kind of long-running, package-installing, file-writing work an agent actually does. Firecracker can.
        </p>
      </div>

      <div class="hidden md:flex md:items-center md:justify-center" aria-hidden="true">
        <svg viewBox="0 0 220 160" width="180" height="132" fill="none" stroke="#111" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
          <path d="M14 28 L 206 24 L 208 134 L 16 138 Z"/>
          <path d="M14 28 L 14 44 M 14 28 L 30 28"/>
          <path d="M206 24 L 206 40 M 206 24 L 190 26"/>
          <path d="M16 138 L 16 122 M 16 138 L 32 138"/>
          <path d="M208 134 L 208 118 M 208 134 L 192 135"/>
          <path d="M62 76 L 70 84 L 62 92" stroke-width="1.4"/>
          <path d="M76 92 L 100 92" stroke-width="1.4"/>
          <path d="M122 64 L 156 62 L 158 102 L 124 104 Z"/>
          <path d="M150 64 L 150 70 L 158 70"/>
          <path d="M128 76 L 152 75 M 128 84 L 152 83 M 128 92 L 144 91" stroke-width="1.2"/>
        </svg>
      </div>
    </div>

    <ul class="mx-auto mt-10 grid max-w-[760px] grid-cols-1 gap-3 md:grid-cols-3">
      {specs.map((s) => (
        <li class="rounded-[12px] border border-border-subtle bg-canvas p-5 text-center">
          <div class="font-mono text-fg-3" style="font-size: 12px; letter-spacing: 0.06em;">{s.spec}</div>
          <div class="mt-2 font-medium text-fg-1" style="font-size: 22px; letter-spacing: -0.015em;">{s.val}</div>
        </li>
      ))}
    </ul>

    <figure class="mx-auto mt-10 max-w-[640px]" aria-labelledby="resume-caption">
      <div class="flex items-center justify-center gap-3" aria-hidden="true">
        <svg viewBox="0 0 64 56" width="64" height="56" fill="none" stroke="#111" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
          <rect x="8" y="14" width="48" height="32" rx="3"/>
          <path d="M14 22 L 50 22" stroke-width="1.2"/>
          <circle cx="14" cy="38" r="1.6" fill="#111"/>
          <circle cx="20" cy="38" r="1.6" fill="#111"/>
          <path d="M14 6 L 24 18 M 18 4 L 30 16 M 28 4 L 38 14" stroke-width="1.2" style="opacity: 0.7;"/>
        </svg>
        <div class="flex flex-col items-center gap-1">
          <span class="font-mono text-fg-3" style="font-size: 11px; letter-spacing: 0.04em;">state →</span>
          <svg width="80" height="14" viewBox="0 0 80 14" fill="none" stroke="#111" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
            <path d="M2 7 L 72 7" stroke-dasharray="3 3"/>
            <path d="M68 2 L 76 7 L 68 12"/>
          </svg>
        </div>
        <svg viewBox="0 0 64 56" width="64" height="56" fill="none" stroke="#111" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
          <rect x="8" y="14" width="48" height="32" rx="3"/>
          <path d="M14 22 L 50 22" stroke-width="1.2"/>
          <circle cx="14" cy="38" r="1.6" fill="#111"/>
          <circle cx="20" cy="38" r="1.6" fill="#111"/>
          <path d="M30 38 L 36 32 M 36 38 L 30 32" stroke-width="1.2" style="opacity: 0.4;"/>
          <path d="M40 32 L 44 36 L 50 28" stroke-width="1.4"/>
        </svg>
      </div>
      <figcaption id="resume-caption" class="mx-auto mt-4 max-w-[520px] text-center text-fg-2" style="font-size: 15px; line-height: 1.55;">
        Host dies mid-step? The run resumes on a different host with the working directory intact. <span class="hl-soft">No checkpointing layer to fail.</span>
      </figcaption>
    </figure>
  </div>
</section>
