    <circle cx="240" cy="46" r="2.4" fill="#111"/>
    <circle cx="298" cy="70" r="2.4" fill="#111"/>
    <path d="M24 60 L 332 60" stroke-dasharray="3 4" style="opacity: 0.4;"/>
    <path d="M332 60 L 332 28"/>
    <path d="M332 28 L 348 32 L 340 36 L 348 40 L 332 44"/>
  </svg>
)}

{kind === 'workbench' && (
