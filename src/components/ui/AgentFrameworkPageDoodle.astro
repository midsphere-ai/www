---
// One-off illustrations for /compare/agent-frameworks. Each is over the
// inline-SVG threshold and would otherwise bloat the page file.
type Kind = 'routes' | 'workbench' | 'pedestal' | 'clipboard' | 'context-vs-window' | 'browser-with-cursor' | 'browser-and-research';

interface Props {
  kind: Kind;
}

const { kind } = Astro.props;
---

{kind === 'routes' && (
  <svg viewBox="0 0 360 120" width="320" height="108" fill="none" stroke="#111" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
