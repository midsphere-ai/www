---
type DoodleKind = 'journal' | 'pencil' | 'closed-book' | 'paper-stack';

interface Props {
  kind: DoodleKind;
  width?: number;
  variant?: 'light' | 'on-dark';
  class?: string;
}

const { kind, width, variant = 'light', class: className } = Astro.props;
const stroke = variant === 'on-dark' ? 'currentColor' : '#111';

const dim: Record<DoodleKind, { vb: string; w: number; h: number }> = {
  journal:       { vb: '0 0 220 180', w: 200, h: 164 },
  pencil:        { vb: '0 0 110 60',  w: 100, h: 56  },
  'closed-book': { vb: '0 0 180 140', w: 160, h: 124 },
  'paper-stack': { vb: '0 0 100 90',  w: 88,  h: 80  },
};

const d = dim[kind];
const w = width ?? d.w;
const h = (w * d.h) / d.w;
---

<svg
  viewBox={d.vb}
  width={w}
  height={h}
  fill="none"
  stroke={stroke}
  stroke-width="1.6"
  stroke-linecap="round"
  stroke-linejoin="round"
  class={className}
  aria-hidden="true"
>
  {kind === 'journal' && (
    <>
      <path d="M22 36 C 60 30, 96 28, 110 38 C 124 28, 160 30, 198 36 L 196 152 C 162 146, 128 146, 110 156 C 92 146, 58 146, 24 152 Z" />
      <path d="M110 38 L 110 156" />
      <path d="M36 56 L 96 52 M 36 70 L 92 66 M 36 84 L 96 80 M 36 98 L 88 94" stroke-width="1.4" />
      <path d="M124 60 L 184 56 M 124 74 L 178 70 M 124 88 L 184 84" stroke-width="1.4" />
      <path d="M150 110 C 148 100, 158 96, 166 102 C 174 108, 174 120, 166 124 C 160 126, 158 132, 158 138" stroke-width="1.4" />
      <circle cx="158" cy="144" r="1.6" fill={stroke} />
      <path d="M22 22 L 32 14 L 38 18 L 30 28" />
      <path d="M30 28 L 26 32 L 22 30 L 22 22" />
      <path d="M36 24 L 32 20" stroke-width="1.2" />
      <path d="M14 44 L 18 48 M 18 44 L 14 48" stroke-width="1.2" />
      <path d="M204 60 L 208 64 M 208 60 L 204 64" stroke-width="1.2" />
      <path d="M200 130 L 204 134 M 204 130 L 200 134" stroke-width="1.2" />
    </>
  )}
  {kind === 'pencil' && (
    <>
      <path d="M14 36 L 18 48 L 30 44 L 26 32 Z" />
      <path d="M26 32 L 90 14" />
      <path d="M30 44 L 94 26" />
      <path d="M26 32 L 30 44" />
      <path d="M90 14 L 100 12 L 102 22 L 94 26 Z" />
      <path d="M14 36 L 6 40" />
      <path d="M18 48 L 10 54" />
      <path d="M40 50 C 48 56, 60 56, 70 52" stroke-width="1.2" />
      <path d="M70 52 L 64 50 M 70 52 L 66 56" stroke-width="1.2" />
    </>
  )}
  {kind === 'closed-book' && (
    <>
      <path d="M28 22 L 152 18 L 156 116 L 32 122 Z" />
      <path d="M28 22 L 32 122" />
      <path d="M40 22 L 44 122" stroke-width="1.2" />
      <path d="M58 36 L 138 32 M 58 50 L 138 46 M 58 64 L 130 60" stroke-width="1.4" />
      <path d="M62 88 C 62 80, 76 78, 84 82 C 92 86, 92 96, 84 100 L 78 102" stroke-width="1.4" />
      <circle cx="78" cy="108" r="1.8" fill={stroke} />
      <path d="M14 130 L 162 126" stroke-dasharray="3 4" stroke-width="1.2" />
    </>
  )}
  {kind === 'paper-stack' && (
    <>
      <path d="M14 26 L 70 22 L 72 70 L 16 74 Z" />
      <path d="M22 18 L 78 14 L 80 62 L 24 66 Z" />
      <path d="M30 10 L 86 6 L 88 54 L 32 58 Z" />
      <path d="M42 18 L 76 16 M 42 26 L 80 24 M 42 34 L 70 32" stroke-width="1.2" />
      <path d="M86 70 L 92 76 M 92 70 L 86 76" stroke-width="1.2" />
    </>
  )}
</svg>
