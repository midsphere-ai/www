---
import type { HTMLAttributes } from 'astro/types';
import { cn } from '../../utils/merge';

type Variant = 'primary' | 'secondary' | 'accent' | 'ghost' | 'ghost-on-dark';

type Props =
  | ({ href: string; variant?: Variant; class?: string } & Omit<HTMLAttributes<'a'>, 'class'>)
  | ({ href?: undefined; variant?: Variant; class?: string; disabled?: boolean } & Omit<HTMLAttributes<'button'>, 'class'>);

const { href, variant = 'primary', class: className, ...rest } = Astro.props as Props & { href?: string; variant?: Variant; class?: string };

const variantClass: Record<Variant, string> = {
  primary: 'btn-primary',
  secondary: 'btn-secondary',
  accent: 'btn-accent',
  ghost: 'btn-ghost',
  'ghost-on-dark': 'btn-ghost-on-dark',
};

const classes = cn('btn', variantClass[variant], className);
---

{href ? (
  <a href={href} class={classes} {...rest as HTMLAttributes<'a'>}>
    <slot />
  </a>
) : (
  <button type="button" class={classes} {...rest as HTMLAttributes<'button'>}>
    <slot />
  </button>
)}
