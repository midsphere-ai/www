---
import type { HTMLAttributes } from 'astro/types';
import { cn } from '../../utils/merge';

type Element = 'div' | 'article' | 'section';

type Props = {
  class?: string;
  as?: Element;
  hover?: boolean;
} & Omit<HTMLAttributes<'div'>, 'class'>;

const { class: className, as: Tag = 'div', hover = true, ...rest } = Astro.props as Props;

const classes = cn('card', hover && 'card-hover', className);
---

<Tag class={classes} {...rest}>
  <slot />
</Tag>
