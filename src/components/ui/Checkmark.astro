---
interface Props {
  size?: number;
  class?: string;
}

const { size = 14, class: className = 'mt-1 shrink-0 text-fg-3' } = Astro.props;
---

<svg
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.6"
  stroke-linecap="round"
  stroke-linejoin="round"
  class={className}
  aria-hidden="true"
>
  <path d="M20 6 9 17l-5-5" />
</svg>
