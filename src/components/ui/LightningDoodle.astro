---
interface Props {
  variant?: 'light' | 'on-dark';
  width?: number;
  class?: string;
}

const { variant = 'light', width = 140, class: className } = Astro.props;
const height = (width * 180) / 220;
const stroke = variant === 'on-dark' ? 'currentColor' : '#111';
const opacity = variant === 'on-dark' ? 0.85 : 1;
---

<svg
  viewBox="0 0 220 180"
  width={width}
  height={height}
  fill="none"
  stroke={stroke}
  stroke-width="1.6"
  stroke-linecap="round"
  stroke-linejoin="round"
  style={`opacity: ${opacity};`}
  class={className}
  aria-hidden="true"
>
