    <circle cx="70" cy="68" r="4"/>
    <path d="M70 72 L 70 92"/>
    <circle cx="80" cy="68" r="0.8" fill="#111"/>
    <circle cx="84" cy="68" r="0.8" fill="#111"/>
    <path d="M104 8 L 104 124" stroke-dasharray="2 3" stroke-width="1.2"/>
