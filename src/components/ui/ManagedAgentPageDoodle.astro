    <path d="M70 64 L 110 96 L 162 108"/>
    <rect x="92" y="22" width="14" height="10" rx="2"/>
    <rect x="124" y="14" width="16" height="10" rx="2"/>
    <rect x="150" y="10" width="14" height="10" rx="2"/>
    <rect x="92" y="92" width="14" height="10" rx="2"/>
    <rect x="124" y="100" width="16" height="10" rx="2"/>
    <rect x="150" y="108" width="14" height="10" rx="2"/>
    <path d="M58 60 L 70 64 L 58 68" stroke-width="1.2"/>
    <path d="M178 38 L 180 32 L 182 38 L 188 40 L 182 42 L 180 48 L 178 42 L 172 40 Z" stroke-width="1.2"/>
  </svg>
)}

{kind === 'metric' && (
  <svg viewBox="0 0 200 130" width="180" height="118" fill="none" stroke="#111" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M6 110 L 196 110" stroke-width="1.2"/>
    <path d="M44 50 L 44 110"/>
