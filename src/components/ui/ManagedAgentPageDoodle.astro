---
// One-off illustrations for /compare/claude-managed-agents.
type Kind = 'fork' | 'orbit-model' | 'orbit-developer' | 'focus' | 'work' | 'world' | 'metric' | 'support';

interface Props {
  kind: Kind;
}

const { kind } = Astro.props;
---

{kind === 'fork' && (
  <svg width="64" height="50" viewBox="0 0 64 50" fill="none" stroke="#111" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" style="opacity: 0.55;" aria-hidden="true">
    <circle cx="32" cy="6" r="2" fill="#111" stroke="none"/>
    <path d="M32 8 C 28 18, 18 26, 10 40"/>
    <path d="M5 35 L 10 42 L 17 38"/>
    <path d="M32 8 C 36 18, 46 26, 54 40"/>
    <path d="M47 38 L 54 42 L 59 35"/>
  </svg>
)}

{kind === 'orbit-model' && (
  <svg viewBox="0 0 240 200" width="100%" height="auto" preserveAspectRatio="xMidYMid meet" fill="none" stroke="#111" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" style="max-width: 320px;" aria-hidden="true">
    <ellipse cx="120" cy="100" rx="94" ry="58" stroke-dasharray="4 5" stroke-width="1.2"/>
    <circle cx="120" cy="100" r="24" fill="#111" stroke="#111"/>
    <circle cx="32" cy="86" r="8" fill="#fff"/>
    <circle cx="84" cy="42" r="6" fill="#fff"/>
    <circle cx="200" cy="58" r="7" fill="#fff"/>
    <circle cx="180" cy="156" r="8" fill="#fff"/>
    <circle cx="58" cy="148" r="6" fill="#fff"/>
  </svg>
)}

{kind === 'orbit-developer' && (
  <svg viewBox="0 0 240 200" width="100%" height="auto" preserveAspectRatio="xMidYMid meet" fill="none" stroke="#111" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" style="max-width: 320px;" aria-hidden="true">
    <ellipse cx="120" cy="100" rx="94" ry="58" stroke-dasharray="4 5" stroke-width="1.2"/>
    <rect x="98" y="78" width="44" height="44" rx="5" fill="#fff"/>
    <path d="M108 96 L 116 104 L 132 88" stroke-width="1.4"/>
    <circle cx="32" cy="86" r="9" fill="#111" stroke="#111"/>
    <circle cx="84" cy="42" r="6" fill="#111" stroke="#111"/>
    <rect x="194" y="50" width="14" height="14" rx="2" fill="#111" stroke="#111"/>
    <circle cx="180" cy="156" r="7" fill="#111" stroke="#111"/>
    <rect x="48" y="142" width="14" height="14" rx="2" fill="#111" stroke="#111"/>
  </svg>
)}

{kind === 'focus' && (
  <svg viewBox="0 0 200 130" width="180" height="118" fill="none" stroke="#111" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <rect x="6" y="14" width="22" height="12" rx="2"/>
    <circle cx="50" cy="22" r="7"/>
    <rect x="14" y="38" width="14" height="14" rx="2"/>
    <path d="M40 38 L 58 36 L 56 52 L 38 54 Z"/>
    <circle cx="20" cy="72" r="6"/>
    <rect x="36" y="64" width="22" height="10" rx="2"/>
    <rect x="14" y="86" width="18" height="14" rx="2"/>
    <circle cx="48" cy="92" r="7"/>
    <rect x="60" y="102" width="14" height="10" rx="2"/>
    <path d="M88 8 L 88 122" stroke-dasharray="2 3" stroke-width="1.2"/>
    <circle cx="148" cy="62" r="34"/>
    <circle cx="148" cy="62" r="22"/>
    <circle cx="148" cy="62" r="10" fill="#111" stroke="#111"/>
    <path d="M186 28 L 152 58" stroke-width="1.2"/>
    <path d="M186 28 L 178 30 M 186 28 L 184 36" stroke-width="1.2"/>
  </svg>
)}

{kind === 'work' && (
  <svg viewBox="0 0 200 130" width="180" height="118" fill="none" stroke="#111" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M6 86 L 88 86" stroke-width="1.2"/>
    <circle cx="22" cy="64" r="9"/>
    <path d="M22 50 L 22 46 M 22 82 L 22 78 M 36 64 L 40 64 M 4 64 L 8 64 M 30 56 L 33 53 M 14 72 L 11 75 M 30 72 L 33 75 M 14 56 L 11 53" stroke-width="1.2"/>
    <path d="M52 46 L 46 56 L 56 66 L 64 56 L 56 46 Z"/>
    <path d="M64 56 L 80 38" stroke-width="1.2"/>
    <path d="M64 76 L 70 70 L 78 74 L 80 82 L 74 88 L 66 84 Z"/>
    <path d="M104 8 L 104 124" stroke-dasharray="2 3" stroke-width="1.2"/>
    <path d="M118 36 L 188 36 L 188 102 L 118 102 Z"/>
    <path d="M118 64 L 188 64 M 153 36 L 153 102" stroke-width="1.2"/>
    <path d="M141 36 C 138 26, 153 26, 153 36" stroke-width="1.2"/>
    <path d="M165 36 C 168 26, 153 26, 153 36" stroke-width="1.2"/>
    <path d="M168 84 L 174 90 L 184 78" stroke-width="1.2"/>
  </svg>
)}

{kind === 'world' && (
  <svg viewBox="0 0 200 130" width="180" height="118" fill="none" stroke="#111" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M8 64 L 70 64"/>
