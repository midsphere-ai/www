---
type DoodleKind = 'notebook' | 'piggy' | 'moon' | 'ticket' | 'people' | 'house';

interface Props {
  kind: DoodleKind;
  class?: string;
}

const { kind, class: className } = Astro.props;

const dimensions: Record<DoodleKind, { vb: string; w: number; h: number }> = {
  notebook: { vb: '0 0 90 90', w: 84, h: 84 },
  piggy:    { vb: '0 0 100 90', w: 92, h: 84 },
  moon:     { vb: '0 0 100 90', w: 92, h: 82 },
  ticket:   { vb: '0 0 100 90', w: 92, h: 82 },
  people:   { vb: '0 0 110 90', w: 100, h: 82 },
  house:    { vb: '0 0 100 90', w: 92, h: 82 },
};

const dim = dimensions[kind];
---

<svg
  viewBox={dim.vb}
  width={dim.w}
  height={dim.h}
  fill="none"
  stroke="#111"
  stroke-width="1.6"
  stroke-linecap="round"
  stroke-linejoin="round"
  class={className}
  aria-hidden="true"
>
  {kind === 'notebook' && (
    <>
      <path d="M22 14 L 72 12 L 74 78 L 24 80 Z"/>
      <path d="M22 24 L 16 24 M 22 36 L 16 36 M 22 48 L 16 48 M 22 60 L 16 60 M 22 72 L 16 72"/>
      <circle cx="16" cy="24" r="2.5"/>
      <circle cx="16" cy="36" r="2.5"/>
      <circle cx="16" cy="48" r="2.5"/>
      <circle cx="16" cy="60" r="2.5"/>
      <circle cx="16" cy="72" r="2.5"/>
      <path d="M40 32 C 40 24, 50 22, 56 26 C 62 30, 62 38, 56 42 C 50 44, 50 52, 50 56" stroke-width="1.4"/>
      <circle cx="50" cy="62" r="1.8" fill="#111"/>
    </>
  )}
  {kind === 'piggy' && (
    <>
      <path d="M14 50 C 14 36, 30 26, 50 26 C 70 26, 86 36, 86 52 C 86 64, 78 72, 70 74 L 68 80 L 60 80 L 58 76 C 54 76, 50 76, 46 76 L 44 80 L 36 80 L 34 74 C 24 72, 14 62, 14 50 Z"/>
      <circle cx="68" cy="46" r="2.5"/>
      <path d="M22 38 C 22 32, 28 30, 32 32 L 28 42"/>
      <path d="M40 24 L 50 16 L 60 24"/>
      <path d="M44 50 L 56 50"/>
    </>
  )}
  {kind === 'moon' && (
    <>
      <path d="M28 16 C 18 22, 14 32, 16 42 C 18 52, 28 58, 38 56 C 30 50, 26 38, 32 26 C 30 22, 28 18, 28 16 Z"/>
      <path d="M50 64 L 90 60 L 90 80 L 50 84 Z"/>
      <path d="M50 70 L 88 66 M 50 76 L 84 72"/>
      <circle cx="64" cy="40" r="9"/>
      <path d="M71 47 L 80 56"/>
    </>
  )}
  {kind === 'ticket' && (
    <>
      <path d="M14 28 L 86 22 L 88 60 C 84 58, 78 60, 78 66 C 78 70, 82 72, 86 72 L 88 76 L 16 82 L 16 76 C 20 76, 22 70, 22 66 C 22 62, 20 58, 16 60 Z"/>
      <path d="M30 36 L 30 70" stroke-dasharray="3 3"/>
      <path d="M48 50 L 56 60 L 74 38"/>
    </>
  )}
  {kind === 'people' && (
    <>
      <circle cx="20" cy="32" r="7"/>
      <path d="M20 39 L 20 60 M 20 60 L 14 76 M 20 60 L 26 76 M 14 50 L 26 50"/>
      <circle cx="36" cy="34" r="3.5"/>
      <circle cx="56" cy="32" r="7"/>
      <path d="M56 39 L 56 60 M 56 60 L 50 76 M 56 60 L 62 76 M 50 50 L 62 50"/>
      <circle cx="72" cy="34" r="3.5"/>
      <circle cx="92" cy="32" r="7"/>
      <path d="M92 39 L 92 60 M 92 60 L 86 76 M 92 60 L 98 76 M 86 50 L 98 50"/>
      <circle cx="108" cy="34" r="3.5"/>
    </>
  )}
  {kind === 'house' && (
    <>
      <path d="M14 44 L 44 18 L 74 44 L 74 78 L 14 78 Z"/>
      <path d="M30 78 L 30 58 L 44 58 L 44 78"/>
      <circle cx="58" cy="56" r="3"/>
      <path d="M58 60 L 58 70"/>
      <circle cx="84" cy="60" r="6"/>
      <path d="M90 60 L 100 60 M 96 60 L 96 64 M 100 60 L 100 64"/>
    </>
  )}
</svg>
