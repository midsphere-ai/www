---
// "Six things you stop doing" card used on /compare/ pages. Doodle on top,
// numbered eyebrow, title, body. Doodle slot stays at the call-site so each
// page can pick its own per-card illustration.
interface Props {
  num: string;
  title: string;
  body: string;
  headingId?: string;
}

const { num, title, body, headingId } = Astro.props;
---

<li class="rounded-[14px] border border-border-subtle bg-canvas p-6 sm:p-7">
  <div class="flex h-[88px] items-center" aria-hidden="true">
    <slot name="doodle" />
  </div>

  <div class="mt-4 flex items-baseline gap-3">
    <span class="font-mono text-fg-3" style="font-size: 12px; letter-spacing: 0.06em;">{num}</span>
    <span class="font-mono text-fg-3" style="font-size: 12px; letter-spacing: 0.06em;">you don’t</span>
  </div>
  <h3
    id={headingId}
    class="mt-2 font-medium text-fg-1"
    style="font-size: 20px; letter-spacing: -0.02em;"
  >
    {title}
  </h3>
  <p class="mt-3 text-fg-2" style="font-size: 15px; line-height: 1.6;">{body}</p>
</li>
