---
import '../styles/global.css';
import SEOHead from '../components/global/SEOHead.astro';
import type { BreadcrumbItem } from '../utils/seo';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonicalURL?: string;
  ogType?: 'website' | 'article';
  publishedDate?: string;
  modifiedDate?: string;
  author?: string;
  noindex?: boolean;
  breadcrumbs?: BreadcrumbItem[];
  faqItems?: { question: string; answer: string }[];
}

const {
  title,
  description = 'Ship the AI feature you sketched on Monday. Internal copilots, batch report generators, voice transcribers, agent workflows.',
  ogImage,
  canonicalURL,
  ogType,
  publishedDate,
  modifiedDate,
  author,
  noindex,
  breadcrumbs,
  faqItems,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#FFFFFF" />
    <link rel="preload" href="/fonts/google-sans-flex-latin.woff2" as="font" type="font/woff2" crossorigin />
    <SEOHead
      title={title}
      description={description}
      ogImage={ogImage}
      canonicalURL={canonicalURL}
      ogType={ogType}
      publishedDate={publishedDate}
      modifiedDate={modifiedDate}
      author={author}
      noindex={noindex}
      breadcrumbs={breadcrumbs}
      faqItems={faqItems}
    />
    <slot name="head" />
  </head>
  <body class="page-fade">
    <a href="#main-content" class="skip-link">Skip to content</a>
    <slot />

    {/* Analytics bootstrap — Sentry + PostHog. Lazy-loaded on idle, never blocks
        first paint. When env vars are unset at build time, Vite tree-shakes the
        SDK imports entirely — zero bytes ship until `.env` is provided. */}
    <script>
      const dnt =
        navigator.doNotTrack === '1' ||
        (window as unknown as { doNotTrack?: string }).doNotTrack === '1';

      const sentryDsn = import.meta.env.PUBLIC_SENTRY_DSN as string | undefined;
      const posthogKey = import.meta.env.PUBLIC_POSTHOG_KEY as string | undefined;
      const posthogHost = (import.meta.env.PUBLIC_POSTHOG_HOST as string | undefined) ?? 'https://us.i.posthog.com';
      const buildSha = import.meta.env.PUBLIC_BUILD_SHA as string | undefined;
      const isProd = import.meta.env.PROD;

      if (!dnt && (sentryDsn || posthogKey)) {
        const init = async () => {
          if (sentryDsn) {
            try {
              const Sentry = await import('@sentry/browser');
              Sentry.init({
                dsn: sentryDsn,
                release: buildSha || undefined,
                environment: isProd ? 'production' : 'development',
                tracesSampleRate: isProd ? 0.1 : 1.0,
                beforeSend(event) {
                  // strip likely-PII before send
                  if (event.request?.cookies) delete event.request.cookies;
                  if (event.user) {
                    delete event.user.email;
                    delete event.user.ip_address;
                  }
                  return event;
                },
              });
            } catch {
              /* analytics is non-blocking; never break the page */
            }
          }

          if (posthogKey) {
            try {
              const { default: posthog } = await import('posthog-js');
              // Memory persistence: nothing written to cookies or localStorage,
              // so no consent banner is required for this marketing surface.
              // Trade-off: visits don't dedupe across reloads. If/when an
              // authed product surface lands here, swap to localStorage+cookie
              // behind an explicit consent gate.
              posthog.init(posthogKey, {
                api_host: posthogHost,
                persistence: 'memory',
                capture_pageview: true,
                capture_pageleave: true,
              });

              // LLM-referrer capture — discovery channel attribution.
              try {
                const ref = document.referrer ? new URL(document.referrer).hostname : '';
                const llmHosts: Record<string, string> = {
                  'chat.openai.com': 'chatgpt',
                  'chatgpt.com': 'chatgpt',
                  'perplexity.ai': 'perplexity',
                  'www.perplexity.ai': 'perplexity',
                  'claude.ai': 'claude',
                  'gemini.google.com': 'gemini',
                };
                const source = llmHosts[ref];
                if (source) posthog.capture('llm_referral', { source, referrer: ref });
              } catch {
                /* referrer parsing is best-effort */
              }
            } catch {
              /* analytics is non-blocking; never break the page */
            }
          }
        };

        const ric = (window as unknown as {
          requestIdleCallback?: (cb: () => void, opts?: { timeout: number }) => void;
        }).requestIdleCallback;
        if (ric) {
          ric(() => void init(), { timeout: 3000 });
        } else {
          window.addEventListener('load', () => setTimeout(() => void init(), 1500), { once: true });
        }
      }
    </script>
  </body>
</html>
