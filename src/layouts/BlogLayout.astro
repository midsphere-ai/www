---
import '../styles/blog.css';
import PageLayout from './PageLayout.astro';
import BlogDoodle from '../components/ui/BlogDoodle.astro';
import Button from '../components/ui/Button.astro';
import NextPostCard from '../components/blog/NextPostCard.astro';
import { formatDate } from '../utils/formatDate';

interface NextPost {
  id: string;
  title: string;
  description: string;
  tags: string[];
}

interface TocHeading {
  slug: string;
  text: string;
}

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  author: string;
  image?: string;
  tags: string[];
  readingTime: number;
  noteNumber?: number;
  totalNotes?: number;
  nextPost?: NextPost | null;
  tocHeadings?: TocHeading[];
}

const {
  title,
  description,
  pubDate,
  updatedDate,
  author,
  image,
  tags,
  readingTime,
  noteNumber,
  totalNotes,
  nextPost,
  tocHeadings = [],
} = Astro.props;

const breadcrumbs = [
  { name: 'Home', url: 'https://midsphere.ai/' },
  { name: 'Blog', url: 'https://midsphere.ai/blog/' },
  { name: title, url: new URL(Astro.url.pathname, Astro.site).href },
];

const issueLabel = noteNumber && totalNotes
  ? `N°${String(noteNumber).padStart(2, '0')} / ${String(totalNotes).padStart(2, '0')}`
  : null;
---

<PageLayout
  title={title}
  description={description}
  ogImage={image}
  ogType="article"
  publishedDate={pubDate.toISOString()}
  modifiedDate={updatedDate?.toISOString()}
  author={author}
  breadcrumbs={breadcrumbs}
>
  <div class="reading-progress" aria-hidden="true">
    <div id="reading-progress-fill" class="reading-progress-fill"></div>
  </div>

  <section class="pt-8 pb-4 lg:pt-12">
    <div class="container-x">
      <nav aria-label="Breadcrumb" class="font-mono text-[12px] text-fg-3" style="letter-spacing: 0.06em;">
        <ol class="flex items-center">
          <li><a href="/" class="hover:text-fg-1 transition-colors">home</a></li>
          <li class="middot" aria-hidden="true">·</li>
          <li><a href="/blog" class="hover:text-fg-1 transition-colors">blog</a></li>
          <li class="middot" aria-hidden="true">·</li>
          <li class="text-fg-2 truncate max-w-[280px]">this note</li>
        </ol>
      </nav>
    </div>
  </section>

  <header class="pb-12 lg:pb-16">
    <div class="container-x">
      <div class="grid grid-cols-1 items-center gap-12 lg:grid-cols-[minmax(0,1fr)_minmax(0,300px)] lg:gap-16">
        <div class="min-w-0 lg:order-1">
          <div class="flex items-center gap-3">
            <span class="lime-square" aria-hidden="true"></span>
            <span class="eyebrow">field note</span>
            {issueLabel && (
              <>
                <span class="middot" aria-hidden="true">·</span>
                <span class="font-mono text-[12px] text-fg-3" style="letter-spacing: 0.08em;">{issueLabel}</span>
              </>
            )}
          </div>

          <h1 id="post-title" class="h-display-lg mt-5">
            {title}
          </h1>

          <p class="mt-5 max-w-[640px] text-fg-2" style="font-size: 18px; line-height: 1.55; text-wrap: pretty;">
            {description}
          </p>

          {tags.length > 0 && (
            <div class="mt-6 flex flex-wrap gap-2">
              {tags.map((tag) => <span class="chip">{tag}</span>)}
            </div>
          )}

          <div class="mt-7 flex flex-wrap items-center font-mono text-[12px] text-fg-3" style="letter-spacing: 0.06em;">
            <span class="text-fg-2">{author}</span>
            <span class="middot" aria-hidden="true">·</span>
            <time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time>
            <span class="middot" aria-hidden="true">·</span>
            <span>{readingTime} min read</span>
            {updatedDate && (
              <>
                <span class="middot" aria-hidden="true">·</span>
                <span>updated <time datetime={updatedDate.toISOString()}>{formatDate(updatedDate)}</time></span>
              </>
            )}
          </div>
        </div>

        <div class="hero-doodle relative flex justify-center lg:order-2 lg:justify-end" aria-hidden="true">
          <div class="hero-doodle-rotate">
            <BlogDoodle kind="paper-stack" width={200} />
          </div>
          <svg class="hero-flourish" viewBox="0 0 60 60" width="44" height="44" fill="none" stroke="#111" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M14 30 L 46 30 M 30 14 L 30 46 M 18 18 L 42 42 M 42 18 L 18 42" opacity="0.5" />
          </svg>
        </div>
      </div>
    </div>
  </header>

  <article class="container-x pb-16">
    <div class="grid grid-cols-1 gap-12 lg:grid-cols-[minmax(0,1fr)_minmax(0,260px)] lg:gap-16">
      <div class="prose min-w-0" style="max-width: 720px;">
        <slot />
        <div class="end-mark" aria-hidden="true">~ end of note ~</div>
      </div>

      {tocHeadings.length > 0 && (
        <aside class="hidden lg:block" aria-label="Contents of this note">
          <nav class="toc-rail sticky">
            <div class="flex items-center gap-2.5">
              <span class="lime-square" aria-hidden="true"></span>
              <span class="eyebrow">in this note</span>
            </div>
            <ol class="toc-list mt-4">
              {tocHeadings.map((h, i) => (
                <li>
                  <a href={`#${h.slug}`} data-toc-link={h.slug}>
                    <span class="toc-num">{String(i + 1).padStart(2, '0')}</span>
                    <span class="toc-text">{h.text}</span>
                  </a>
                </li>
              ))}
            </ol>
            <div class="toc-meta mt-6">
              <span>{readingTime} min</span>
              <span class="middot" aria-hidden="true">·</span>
              <span>{tocHeadings.length} sections</span>
            </div>
          </nav>
        </aside>
      )}
    </div>
  </article>

  {nextPost && <NextPostCard post={nextPost} />}

  <section class="pb-20">
    <div class="container-x">
      <div class="mx-auto max-w-[720px] border-t border-border-subtle pt-12 text-center">
        <div class="mx-auto mb-4 flex justify-center" aria-hidden="true">
          <BlogDoodle kind="pencil" width={120} />
        </div>
        <p class="mx-auto max-w-[520px] font-medium text-fg-1" style="font-size: clamp(20px, 2.2vw, 24px); line-height: 1.35; letter-spacing: -0.015em; text-wrap: balance;">
          End of this note. <span class="hl-soft">Want to ship the thing it's about?</span>
        </p>
        <div class="mt-7 flex flex-wrap justify-center gap-2.5">
          <Button href="https://platform.midsphere.ai" variant="primary">Start building</Button>
          <Button href="/blog" variant="secondary">More notes</Button>
        </div>
      </div>
    </div>
  </section>
</PageLayout>

<script>
  import { initBlogReadingProgress } from '../scripts/blogReadingProgress';
  import { initBlogTocHighlight } from '../scripts/blogTocHighlight';

  let disposers: Array<() => void> = [];
  const start = () => {
    disposers = [initBlogReadingProgress(), initBlogTocHighlight()];
  };
  const stop = () => {
    disposers.forEach((fn) => fn());
    disposers = [];
  };
  start();
  document.addEventListener('astro:before-swap', stop);
  document.addEventListener('astro:after-swap', start);
</script>
