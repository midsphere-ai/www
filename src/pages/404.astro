---
import PageLayout from '../layouts/PageLayout.astro';
import Button from '../components/ui/Button.astro';
---

<PageLayout title="Page not found — Midsphere" description="404 — the page you were looking for is not here." noindex>
  <section class="flex flex-col items-center justify-center px-5 py-32 text-center">
    <div class="font-mono text-[12px] uppercase text-fg-3" style="letter-spacing: 0.06em;">404</div>
    <h1 id="not-found-headline" class="h-display-lg mt-4 max-w-[640px]">
      This page <span class="hl">isn't here</span>.
    </h1>
    <p class="mt-5 max-w-[480px] text-fg-2" style="font-size: 16px; line-height: 1.55;">
      It may have moved, been renamed, or never existed. The home page is a good place to start.
    </p>
    <div class="mt-8 flex justify-center gap-2.5">
      <Button href="/" variant="primary">Back home</Button>
      <Button href="/features" variant="secondary">Browse features</Button>
    </div>
  </section>
</PageLayout>
