---
import PageLayout from '../layouts/PageLayout.astro';
import ClosingCTA from '../components/sections/ClosingCTA.astro';

const primary = [
  { eyebrow: 'GAIA',  title: '83.2',  unit: '%', body: 'General-purpose agent benchmark. Long-horizon, tool-using tasks across the open web.' },
  { eyebrow: 'IMO',   title: '6 / 6', unit: '', body: 'International Math Olympiad. Reasoning under strict proof requirements.' },
  { eyebrow: 'ICPC',  title: '94',    unit: '%', body: 'Competitive programming. Generate code, run it, fix what breaks — end to end.' },
];

const secondary = [
  { name: 'SWE-bench Verified',   value: '72%' },
  { name: 'MMLU',                 value: '88%' },
  { name: 'HumanEval',            value: '95%' },
  { name: 'GSM8K',                value: '97%' },
  { name: 'TerminalBench',        value: '81%' },
  { name: 'Cost per 1K tasks',    value: '$2.40' },
];
---

<PageLayout
  title="Benchmarks — Midsphere"
  description="Numbers we publish. Numbers we run nightly. The harness that produces them is open."
  breadcrumbs={[
    { name: 'Home', url: 'https://midsphere.ai' },
    { name: 'Benchmarks', url: 'https://midsphere.ai/benchmarks' },
  ]}
>
  <section class="section-tight text-center">
    <div class="container-x">
      <div class="eyebrow">benchmarks</div>
      <h1 id="benchmarks-headline" class="h-display-lg mx-auto mt-3 max-w-[820px]">
        Numbers we <span class="hl">publish</span>. Nightly.
      </h1>
      <p class="mx-auto mt-5 max-w-[640px] text-fg-2" style="font-size: 18px; line-height: 1.55;">
        The harness is open. Re-run any of these on your own infra. No cherry-picked configs, no marketing math.
      </p>
    </div>
  </section>

  <section class="section-tight">
    <div class="container-x">
      <div class="grid grid-cols-1 gap-4 md:grid-cols-3">
        {primary.map((b) => (
          <article class="card card-feature">
            <div class="eyebrow">{b.eyebrow}</div>
            <div class="mt-4 flex items-baseline gap-1">
              <span class="font-medium" style="font-size: 56px; line-height: 1; letter-spacing: -0.025em;">{b.title}</span>
              <span class="text-fg-2 text-[18px]">{b.unit}</span>
            </div>
            <p class="mt-4 text-[14px] leading-relaxed text-fg-2">{b.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container-x">
      <div class="mb-10">
        <div class="eyebrow">secondary</div>
        <h2 id="benchmarks-board" class="h-section mt-3 max-w-[720px]">
          The full board.
        </h2>
      </div>
      <div class="rounded-[18px] border border-border-subtle">
        {secondary.map((row, i) => (
          <div class={`flex items-center justify-between px-6 py-4 ${i < secondary.length - 1 ? 'border-b border-border-subtle' : ''}`}>
            <div class="text-[15px] text-fg-1">{row.name}</div>
            <div class="font-mono text-[15px] text-fg-1">{row.value}</div>
          </div>
        ))}
      </div>
      <p class="mt-6 font-mono text-[12px] text-fg-3" style="letter-spacing: 0.06em;">
        last run · 2026-04-24 03:00 utc · commit 3e9e954 · seed 42
      </p>
    </div>
  </section>

  <ClosingCTA />
</PageLayout>
