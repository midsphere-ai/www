---
import PageLayout from '../../layouts/PageLayout.astro';
import ScrollDownArrow from '../../components/ui/ScrollDownArrow.astro';
import StopDoingCard from '../../components/ui/StopDoingCard.astro';
import CloudProviderDoodle from '../../components/ui/CloudProviderDoodle.astro';
import CloudProviderPageDoodle from '../../components/ui/CloudProviderPageDoodle.astro';
import FitFramework from '../../components/ui/FitFramework.astro';
import ScenarioCard from '../../components/ui/ScenarioCard.astro';
import ClosingPanel from '../../components/ui/ClosingPanel.astro';

interface Stop {
  num: string;
  title: string;
  body: string;
  doodle: 'model' | 'context' | 'paper' | 'prompt' | 'infra' | 'hire';
}

const stops: Stop[] = [
  { num: '01', title: 'Pick a model.',         body: 'We route across providers per call. A better model ships? We start using it. Your code doesn’t move.',                  doodle: 'model'   },
  { num: '02', title: 'Manage context.',       body: 'The agent decides what to keep, what to summarise, what to recall. Window overflow isn’t on your roadmap.',                doodle: 'context' },
  { num: '03', title: 'Read the latest paper.', body: 'New techniques, new architectures, new tricks. We absorb them into the same SDK call.',                                    doodle: 'paper'   },
  { num: '04', title: 'Write system prompts.', body: 'Set policies — spend caps, approvals, allowed tools. The agent reads them as constraints, not suggestions.',               doodle: 'prompt'  },
  { num: '05', title: 'Run infrastructure.',   body: 'No sandboxes, no state to manage, no recovery to wire. The agent runs and recovers from its own failures.',                doodle: 'infra'   },
  { num: '06', title: 'Hire AI engineers.',    body: 'The agent is the product, not the project. Three lines of code and you’re shipping the feature.',                          doodle: 'hire'    },
];

const cloudFit: string[] = [
  'You have engineers who want to own the agent’s design — models, context, prompts, all of it.',
  'You’re already deep on AWS, Azure, or GCP and want vertical integration.',
  'The agent is one piece of a broader internal platform.',
];

const midsphereFit: string[] = [
  'You don’t have AI engineers and don’t plan to hire any.',
  'You want the feature live this month, not the quarter your platform team takes.',
  'You’d rather not read papers and pick models for a living.',
];
---

<PageLayout
  title="Midsphere vs. cloud-provider agents — Compare"
  description="AWS Bedrock Agents, Azure AI Foundry Agent Service, and Google Vertex AI Agents are toolkits for teams building their own agent. Midsphere is the agent. Here's how to tell which fits."
  breadcrumbs={[
    { name: 'Home', url: 'https://midsphere.ai' },
    { name: 'Compare', url: 'https://midsphere.ai/compare' },
    { name: 'Cloud providers', url: 'https://midsphere.ai/compare/cloud-providers' },
  ]}
>
  <section id="compare-cloud" class="section-tight pt-12 lg:pt-16">
    <div class="container-x text-center">
      <div class="eyebrow">compare · cloud-provider agents</div>
      <h1 id="hero-headline" class="h-display-lg mx-auto mt-3 max-w-[820px]">
        Skip the agent. <span class="hl">Ship the feature</span>.
      </h1>
      <p class="mx-auto mt-6 max-w-[600px] text-fg-2" style="font-size: 18px; line-height: 1.6;">
        AWS Bedrock Agents, Azure AI Foundry Agent Service, and Google Vertex AI Agents give you the parts to build a production agent. We give you the agent.
      </p>
      <div class="mx-auto mt-10 flex justify-center">
        <ScrollDownArrow />
      </div>
    </div>
  </section>

  <section id="cloud-side" class="section">
    <div class="container-x">
      <div class="mx-auto grid max-w-[1080px] grid-cols-1 items-center gap-10 md:grid-cols-[1fr_220px] md:gap-14">
        <div>
          <div class="eyebrow">the cloud-provider services</div>
          <h2 id="cloud-headline" class="h-section mt-3 max-w-[520px]">
            Toolkits for teams who want the parts.
          </h2>
          <p class="mt-5 max-w-[520px] text-fg-2" style="font-size: 17px; line-height: 1.65;">
            Models, runtime, identity, governance, deep ties into the cloud you already run. Your team designs and operates <span class="hl-soft">the agent itself</span>.
          </p>
          <p class="mt-4 max-w-[520px] text-fg-1" style="font-size: 17px; line-height: 1.65;">
            That’s a real product. It’s just a different one.
          </p>
        </div>
        <div class="hidden md:flex md:items-center md:justify-center">
          <CloudProviderPageDoodle kind="crates" />
        </div>
      </div>
    </div>
  </section>

  <section id="horizon" class="section border-t border-border-subtle">
    <div class="container-x">
      <div class="mx-auto max-w-[640px] text-center">
        <div class="eyebrow">where the work lives</div>
        <h2 id="horizon-headline" class="h-section mt-3">
          Above the line is yours. <span class="hl">Below is ours</span>.
        </h2>
      </div>

      <figure class="mx-auto mt-12 max-w-[760px]" aria-labelledby="horizon-caption">
        <div class="grid grid-cols-1 items-center gap-4 md:grid-cols-[120px_1fr_120px] md:gap-6">
          <div class="hidden md:block text-right" aria-hidden="true">
            <div class="font-mono text-fg-1" style="font-size: 12px; letter-spacing: 0.04em;">your product</div>
            <div class="mt-1 font-mono text-fg-3" style="font-size: 11px; letter-spacing: 0.04em;">you ship this</div>
          </div>
          <div class="flex justify-center">
            <CloudProviderPageDoodle kind="horizon" />
          </div>
          <div class="hidden md:block" aria-hidden="true">
            <div class="font-mono text-fg-1" style="font-size: 12px; letter-spacing: 0.04em;">everything else</div>
            <div class="mt-1 font-mono text-fg-3" style="font-size: 11px; letter-spacing: 0.04em;">we run this</div>
          </div>
        </div>
        <figcaption id="horizon-caption" class="mx-auto mt-6 max-w-[520px] text-center text-fg-2" style="font-size: 15px; line-height: 1.55;">
          The cloud-provider model lets you reach below the line. We don’t make you go down there.
        </figcaption>
      </figure>
    </div>
  </section>

  <section id="stop-doing" class="section">
    <div class="container-x">
      <div class="mx-auto max-w-[640px] text-center">
        <div class="eyebrow">what you stop doing</div>
        <h2 id="stop-doing-headline" class="h-section mt-3">
          Six things <span class="hl">you don’t have to do</span>.
        </h2>
        <p class="mx-auto mt-5 max-w-[560px] text-fg-2" style="font-size: 17px; line-height: 1.6;">
          Each one is real engineering work. Build the agent yourself and it lands on your team.
        </p>
      </div>

      <ul class="mx-auto mt-12 grid max-w-[1080px] grid-cols-1 gap-5 md:grid-cols-2 md:gap-6 lg:grid-cols-3" role="list">
        {stops.map((s) => (
          <StopDoingCard num={s.num} title={s.title} body={s.body} headingId={`stop-${s.num}`}>
            <CloudProviderDoodle slot="doodle" kind={s.doodle} />
          </StopDoingCard>
        ))}
      </ul>
    </div>
  </section>

  <section id="fit" class="section border-t border-border-subtle">
    <div class="container-x">
      <div class="mx-auto max-w-[600px] text-center">
        <div class="eyebrow">which one fits</div>
        <h2 id="fit-headline" class="h-section mt-3">
          Read both. Pick the one that sounds like you.
        </h2>
      </div>

      <FitFramework
        leftLabel="choose a cloud-provider service if"
        leftItems={cloudFit}
        rightLabel="choose midsphere if"
        rightItems={midsphereFit}
      >
        <svg slot="leftIcon" viewBox="0 0 32 32" width="28" height="28" fill="none" stroke="#111" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
          <rect x="5" y="8" width="22" height="18" rx="2"/>
          <path d="M12 8 L 12 26 M 20 8 L 20 26" stroke-width="1.2"/>
        </svg>
        <svg slot="rightIcon" viewBox="0 0 32 32" width="28" height="28" fill="none" stroke="#111" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="16" cy="16" r="11"/>
          <path d="M11 16 L 15 20 L 22 12" stroke-width="1.4"/>
        </svg>
      </FitFramework>
    </div>
  </section>

  <section id="scenarios" class="section">
    <div class="container-x">
      <div class="mx-auto max-w-[600px] text-center">
        <div class="eyebrow">in practice</div>
        <h2 id="scenarios-headline" class="h-section mt-3">
          Two real situations. Two different right answers.
        </h2>
      </div>

      <div class="mx-auto mt-12 grid max-w-[1080px] grid-cols-1 gap-5 md:grid-cols-2 md:gap-6">
        <ScenarioCard
          num="01"
          title="500-person company on AWS. Internal agent service."
          body="Platform team with AI engineers and a multi-year AWS contract. They want to own the agent’s design and tie it into the data warehouse they already run."
          verdictHighlight="AWS Bedrock Agents is the right call."
          verdict="They want the toolkit, not the agent."
          headingId="scenario-platform"
        >
          <CloudProviderPageDoodle slot="doodle" kind="tower" />
        </ScenarioCard>

        <ScenarioCard
          num="02"
          title="5-person startup. AI feature. Live this month."
          body="Five engineers, no AI specialist. Feature ships by month-end or it doesn’t. They’re still hunting for product-market fit."
          verdictHighlight="Midsphere is the right call."
          verdict="They want the feature, not the project."
          headingId="scenario-startup"
        >
          <CloudProviderPageDoodle slot="doodle" kind="lightbulb" />
        </ScenarioCard>
      </div>
    </div>
  </section>

  <ClosingPanel
    eyebrow="if you’d rather ship the feature"
    primaryHref="https://platform.midsphere.ai"
    primaryLabel="Start building"
    secondaryHref="/docs"
    secondaryLabel="Read the docs"
    headingId="ship-headline"
  >
    <Fragment slot="headline">
      They sell the building blocks.<br /><span class="hl text-on-inverse-1">We sell the result</span>.
    </Fragment>
    <Fragment slot="body">
      You write the SDK call. You set the policies. We handle everything else.
    </Fragment>
  </ClosingPanel>
</PageLayout>
