---
import PageLayout from '../layouts/PageLayout.astro';
import ClosingCTA from '../components/sections/ClosingCTA.astro';

const features = [
  {
    slug: 'research',
    eyebrow: 'analysis',
    title: 'Deep research',
    body: 'Pull from hundreds of sources. Get a structured, cited brief in minutes.',
    points: [
      '200+ sources per query: papers, news, proprietary databases',
      'Inline citations and confidence scores',
      'Export to Markdown, PDF, or Google Docs',
    ],
  },
  {
    slug: 'builder',
    eyebrow: 'development',
    title: 'Full-stack builder',
    body: 'Describe your app. Midsphere drafts the frontend, backend, schema, and deploy.',
    points: [
      'Generate Next.js, React, Vue, or Astro frontends with Tailwind',
      'Provision Postgres, Supabase, or MongoDB and write migrations',
      'Deploy to Vercel, Railway, or your own infra with CI/CD',
    ],
  },
  {
    slug: 'automation',
    eyebrow: 'automation',
    title: 'Workflow automation',
    body: 'Connect tools. Describe triggers and actions in plain English. Midsphere routes the rest.',
    points: [
      '"When a new PR is opened, review the code and post to Slack"',
      'Chain multi-step workflows across 500+ platforms — no glue code',
      'Run on a schedule: daily, weekly, or custom cron',
    ],
  },
  {
    slug: 'integrations',
    eyebrow: 'connectors',
    title: 'Smart integrations',
    body: '500+ platforms via OAuth. Slack, GitHub, Sheets, Notion, Salesforce — one click.',
    points: [
      'OAuth — no API keys to manage, no webhooks to wire',
      'Bidirectional read and write across connected systems',
      'Bring your own MCP server when you need to',
    ],
  },
];
---

<PageLayout
  title="Features — Midsphere"
  description="Research, build, automate. The four things Midsphere does, and how they ship together."
  breadcrumbs={[
    { name: 'Home', url: 'https://midsphere.ai' },
    { name: 'Features', url: 'https://midsphere.ai/features' },
  ]}
>
  <section class="section-tight text-center">
    <div class="container-x">
      <div class="eyebrow">features</div>
      <h1 id="features-headline" class="h-display-lg mx-auto mt-3 max-w-[820px]">
        Research, build, automate. <span class="hl">Ship</span>.
      </h1>
      <p class="mx-auto mt-5 max-w-[640px] text-fg-2" style="font-size: 18px; line-height: 1.55;">
        Four things Midsphere does. How they fit together. What you write to use them.
      </p>
    </div>
  </section>

  <section class="section-tight">
    <div class="container-x">
      <div class="grid grid-cols-1 gap-4 lg:grid-cols-2">
        {features.map((f) => (
          <article class="card card-feature card-hover flex flex-col">
            <div class="eyebrow">{f.eyebrow}</div>
            <h2 id={`feature-${f.slug}`} class="mt-3 font-medium" style="font-size: 26px; line-height: 1.18; letter-spacing: -0.02em;">
              {f.title}
            </h2>
            <p class="mt-3 text-[15px] leading-relaxed text-fg-2">{f.body}</p>
            <ul class="mt-5 flex flex-col gap-2 border-t border-border-subtle pt-5" role="list">
              {f.points.map((p) => (
                <li class="flex items-start gap-2.5 text-[14px] text-fg-1">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="mt-1 shrink-0 text-fg-3" aria-hidden="true">
                    <path d="M20 6 9 17l-5-5" />
                  </svg>
                  <span>{p}</span>
                </li>
              ))}
            </ul>
          </article>
        ))}
      </div>
    </div>
  </section>

  <ClosingCTA />
</PageLayout>
