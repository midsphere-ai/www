---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/global/Navbar.astro';
import Footer from '../components/global/Footer.astro';
import Hero from '../components/sections/Hero.astro';
import Premise from '../components/sections/Premise.astro';
import BringYourOwn from '../components/sections/BringYourOwn.astro';
import Range from '../components/sections/Range.astro';
import Scale from '../components/sections/Scale.astro';
import Pricing from '../components/sections/Pricing.astro';
import DayInLife from '../components/sections/DayInLife.astro';
import ClosingCTA from '../components/sections/ClosingCTA.astro';
---

<BaseLayout
  title="Midsphere — ship the AI feature you sketched this morning"
  description="Spawn autonomous agents in three lines of code. The agent you'd spend three months building, ready by afternoon."
>
  <Navbar />
  <main id="main-content">
    <Hero />
    <Premise />
    <BringYourOwn />
    <Range />
    <Scale />
    <Pricing />
    <DayInLife />
    <ClosingCTA />
  </main>
  <Footer />
</BaseLayout>
