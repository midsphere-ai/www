---
import PageLayout from '../layouts/PageLayout.astro';
import ClosingCTA from '../components/sections/ClosingCTA.astro';

const categories = [
  {
    eyebrow: 'communication',
    items: ['Slack', 'Discord', 'Microsoft Teams', 'Email', 'Zoom', 'Linear', 'Telegram', 'Twilio'],
  },
  {
    eyebrow: 'data & storage',
    items: ['PostgreSQL', 'Supabase', 'Snowflake', 'BigQuery', 'MongoDB', 'Redis', 'Airtable', 'Notion'],
  },
  {
    eyebrow: 'productivity',
    items: ['Google Drive', 'Sheets', 'Docs', 'Calendar', 'Dropbox', 'OneDrive', 'Confluence', 'Jira'],
  },
  {
    eyebrow: 'developer',
    items: ['GitHub', 'GitLab', 'Bitbucket', 'Vercel', 'Netlify', 'Railway', 'AWS', 'Cloudflare'],
  },
  {
    eyebrow: 'sales & support',
    items: ['Salesforce', 'HubSpot', 'Pipedrive', 'Intercom', 'Zendesk', 'Freshdesk', 'Stripe', 'Square'],
  },
  {
    eyebrow: 'marketing',
    items: ['Mailchimp', 'Klaviyo', 'Customer.io', 'SendGrid', 'Posthog', 'Mixpanel', 'Segment', 'Amplitude'],
  },
];
---

<PageLayout
  title="Integrations — Midsphere"
  description="500+ platforms via OAuth. Connect once, route work across your stack."
  breadcrumbs={[
    { name: 'Home', url: 'https://midsphere.ai' },
    { name: 'Integrations', url: 'https://midsphere.ai/integrations' },
  ]}
>
  <section class="section-tight text-center">
    <div class="container-x">
      <div class="eyebrow">integrations</div>
      <h1 id="integrations-headline" class="h-display-lg mx-auto mt-3 max-w-[820px]">
        Connect once. <span class="hl">Route everywhere</span>.
      </h1>
      <p class="mx-auto mt-5 max-w-[640px] text-fg-2" style="font-size: 18px; line-height: 1.55;">
        500+ platforms via OAuth. Slack, GitHub, Sheets, Notion, Salesforce — and the long tail beyond.
      </p>
    </div>
  </section>

  <section class="section-tight">
    <div class="container-x">
      <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
        {categories.map((c) => (
          <article class="card card-feature">
            <div class="eyebrow">{c.eyebrow}</div>
            <div class="mt-4 flex flex-wrap gap-2">
              {c.items.map((item) => (
                <span class="chip">{item}</span>
              ))}
            </div>
          </article>
        ))}
      </div>

      <p class="mt-8 text-center font-mono text-[12px] text-fg-3" style="letter-spacing: 0.06em;">
        plus 400+ more · request integrations at hello@midsphere.ai
      </p>
    </div>
  </section>

  <ClosingCTA />
</PageLayout>
