---
import PageLayout from '../layouts/PageLayout.astro';
import Button from '../components/ui/Button.astro';
import CodeBlock from '../components/ui/CodeBlock.astro';
import ClosingCTA from '../components/sections/ClosingCTA.astro';

const sample = `from orbiter import Agent

agent = Agent(
  name="researcher",
  tools=[search, summarize, cite],
)

result = agent.run("Brief me on Q3 SaaS pricing trends")
print(result.report)`;
---

<PageLayout
  title="Orbiter — the open-source framework behind Midsphere"
  description="Orbiter is the multi-agent framework underneath Midsphere. Open-source, MIT, yours to fork and self-host."
  breadcrumbs={[
    { name: 'Home', url: 'https://midsphere.ai' },
    { name: 'Orbiter', url: 'https://midsphere.ai/orbiter' },
  ]}
>
  <section class="section-tight text-center">
    <div class="container-x">
      <div class="eyebrow">orbiter — the framework</div>
      <h1 id="orbiter-headline" class="h-display-lg mx-auto mt-3 max-w-[820px]">
        The framework <span class="hl">behind</span> Midsphere.
      </h1>
      <p class="mx-auto mt-5 max-w-[680px] text-fg-2" style="font-size: 18px; line-height: 1.55;">
        Open-source. Multi-agent. Built for shipping. The same engine that runs Midsphere — yours to fork, extend, and self-host.
      </p>
      <div class="mt-8 flex justify-center gap-2.5">
        <Button href="https://github.com/midsphere/orbiter" variant="primary">View on GitHub</Button>
        <Button href="https://orbiter.midsphere.ai" variant="secondary">Read the docs</Button>
      </div>
    </div>
  </section>

  <section class="section-tight">
    <div class="container-x">
      <article class="rounded-[18px] bg-inverse p-7 text-on-inverse-1">
        <div class="font-mono text-[12px] uppercase" style="color: var(--ms-fg-on-inverse-2); letter-spacing: 0.06em;">spawn an agent</div>
        <CodeBlock code={sample} variant="on-dark" class="mt-4" />
      </article>
    </div>
  </section>

  <section class="section">
    <div class="container-x">
      <div class="mb-10 text-center">
        <div class="eyebrow">what's in the box</div>
        <h2 id="orbiter-pieces" class="h-section mx-auto mt-3 max-w-[720px]">
          Six pieces. <span class="hl">One agent.</span>
        </h2>
      </div>
      <div class="grid grid-cols-1 gap-4 md:grid-cols-3">
        {[
          { eyebrow: 'steps',    body: 'Break work into ordered steps. Dependencies and parallelism declared in code, not config.' },
          { eyebrow: 'runtimes', body: 'Run locally, in your VPC, or on managed cloud. Same agent definition, different homes.' },
          { eyebrow: 'memory',   body: 'Short- and long-term memory backends: SQLite, Postgres, vector stores. Bring your own.' },
          { eyebrow: 'tools',    body: '@tool decorator turns any Python function into an agent capability. Typed inputs, structured outputs.' },
          { eyebrow: 'mcp',      body: 'First-class Model Context Protocol support. Connect to any MCP server with one line.' },
          { eyebrow: 'streaming',body: 'Stream every event: tool calls, deltas, errors. Forward straight to your UI.' },
        ].map((item) => (
          <article class="card card-feature">
            <div class="eyebrow">{item.eyebrow}</div>
            <p class="mt-3 text-[15px] leading-relaxed text-fg-1">{item.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <ClosingCTA />
</PageLayout>
