---
import PageLayout from '../layouts/PageLayout.astro';
import ClosingCTA from '../components/sections/ClosingCTA.astro';
import PricingTier from '../components/ui/PricingTier.astro';

// Suggested top-up amounts. Not tiers — convenient defaults. Any amount works.
const topUps = ['$20', '$50', '$100', '$500'];

const freeBullets = [
  'Free credits on signup',
  '1–2 concurrent agents',
  'All features included',
];

const prepaidBullets = [
  'Pay only for what you use',
  '10–15 concurrent agents',
  'Hard spend caps you control',
  'Credits never expire',
];

const enterpriseBullets = [
  'Volume pricing',
  'Unlimited concurrency',
  'BYOK, on-prem, or BYO cloud',
  'SAML, audit log streaming, dedicated support',
];

const exampleRuns = [
  { name: 'Inbox triage',   detail: 'A few API calls, one model, < 30s',                       cost: '~ $0.05' },
  { name: 'Research brief', detail: 'Web + docs + a couple of tool chains, ~15 min',          cost: '~ $0.40' },
  { name: 'Long pipeline',  detail: 'Code + browser + multi-step recovery, ~1 hr',            cost: '~ $1.20' },
];
---

<PageLayout
  title="Pricing — Midsphere"
  description="Pay for the work. Not the seat. Not the month. Prepaid credits, no subscription, credits never expire."
  breadcrumbs={[
    { name: 'Home', url: 'https://midsphere.ai' },
    { name: 'Pricing', url: 'https://midsphere.ai/pricing' },
  ]}
>
  <section class="pt-12 pb-10 text-center lg:pt-16 lg:pb-12">
    <div class="container-x">
      <div class="mx-auto flex justify-center doodle-float" aria-hidden="true">
        <svg viewBox="0 0 96 78" width="84" height="68" fill="none" stroke="#111" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
          <ellipse cx="48" cy="14" rx="28" ry="6.5"/>
          <path d="M20 14 L 21 30"/>
          <path d="M76 14 L 75 30"/>
          <path d="M21 30 Q 48 36, 75 30"/>
          <path d="M21 30 L 22 46"/>
          <path d="M75 30 L 74 46"/>
          <path d="M22 46 Q 48 53, 74 46"/>
          <path d="M22 46 L 24 62"/>
          <path d="M74 46 L 72 62"/>
          <path d="M24 62 Q 48 70, 72 62"/>
          <path d="M48 9 L 48 19" stroke-width="1.3"/>
          <path d="M44 11 Q 48 8, 52 11" stroke-width="1.3"/>
          <path d="M44 17 Q 48 20, 52 17" stroke-width="1.3"/>
          <path d="M84 4 L 86 18" stroke-width="1.3" style="opacity: 0.55;"/>
          <path d="M83 14 L 86 18 L 89 14" stroke-width="1.3" style="opacity: 0.55;"/>
        </svg>
      </div>

      <div class="eyebrow mt-5">credits</div>
      <h1 id="pricing-headline" class="h-display-lg mx-auto mt-3 max-w-[820px]">
        Pricing that <span class="hl">respects your weekend</span>.
      </h1>
      <p class="mx-auto mt-5 max-w-[640px] text-fg-2" style="font-size: 18px; line-height: 1.55;">
        Pay for the work. Not the seat. Not the month.
      </p>
    </div>
  </section>

  <section class="pt-2 pb-12 lg:pb-16">
    <div class="container-x">
      <div class="grid grid-cols-1 gap-4 lg:grid-cols-3">
        <PricingTier
          eyebrow="free"
          price="$0"
          priceSuffix="to start"
          body="Free credits on signup. No card. Enough to wire it in and watch the agent do something real on your own task."
          bullets={freeBullets}
          ctaHref="https://platform.midsphere.ai"
          ctaLabel="Start building"
        />

        <PricingTier
          eyebrow="prepaid credits"
          price=""
          body="Buy credits, spend them when you want. Top up at a threshold you choose, or refill manually. The credits sit there until you use them."
          bullets={prepaidBullets}
          ctaHref="https://platform.midsphere.ai"
          ctaLabel="Buy credits"
          accent
          featured
          featuredLabel="most builders start here"
        >
          <div slot="price">
            <div class="mt-5 flex flex-wrap gap-2">
              {topUps.map((amt) => (
                <span
                  class="font-medium"
                  style="font-size: 18px; line-height: 1; padding: 8px 14px; background: rgba(0,0,0,0.07); border-radius: var(--r-pill); letter-spacing: -0.005em;"
                >{amt}</span>
              ))}
            </div>
            <p class="mt-3 text-[13px]" style="opacity: 0.8;">or any amount you want. No minimum, no commitment.</p>
          </div>
        </PricingTier>

        <PricingTier
          eyebrow="enterprise"
          price="Custom"
          priceSuffix="contract & support"
          body="For teams running agents in production, with compliance requirements, dedicated support, or self-hosted deployment."
          bullets={enterpriseBullets}
          ctaHref="mailto:enterprise@midsphere.ai"
          ctaLabel="Talk to us"
        />
      </div>

      <p class="mt-7 text-center font-mono text-[12px] text-fg-3" style="letter-spacing: 0.06em;">
        no subscription · no monthly minimum · credits never expire
      </p>
    </div>
  </section>

  <section class="section border-t border-border-subtle">
    <div class="container-x">
      <div class="mb-8 text-center">
        <div class="eyebrow">what credits buy</div>
        <h2 id="pricing-what-credits-buy" class="h-section mx-auto mt-3 max-w-[760px]">
          You pay for the work, <span class="hl-soft">not the seat</span>.
        </h2>
      </div>

      <p class="mx-auto max-w-[680px] text-center text-fg-2" style="font-size: 17px; line-height: 1.6;">
        Credits cover the actual work the agent does — model calls, compute time, tool invocations.
        Heavy work costs more credits; light work costs fewer. There's no per-seat fee, no platform fee, no monthly minimum.
      </p>

      <div class="mx-auto mt-10 max-w-[640px] rounded-[18px] border border-border-subtle p-7" style="background: var(--ms-bg-sunken);">
        <div class="flex items-baseline justify-between gap-4">
          <div class="font-mono text-[11px] uppercase text-fg-3" style="letter-spacing: 0.08em;">what runs cost</div>
          <div class="font-mono text-[11px] uppercase text-fg-3" style="letter-spacing: 0.08em;">typical</div>
        </div>

        <ul class="mt-4 flex flex-col" role="list">
          {exampleRuns.map((run) => (
            <li class="flex items-baseline justify-between gap-4 border-t border-border-subtle py-3.5">
              <div>
                <div class="text-[15px] text-fg-1">{run.name}</div>
                <div class="mt-1 text-[13px] text-fg-2">{run.detail}</div>
              </div>
              <span class="font-mono text-[15px] text-fg-1" style="font-variant-numeric: tabular-nums;">{run.cost}</span>
            </li>
          ))}
        </ul>

        <p class="mt-5 text-[13px] text-fg-2">
          You see the running total per agent. Past your spend cap, the agent stops on its own.
        </p>
      </div>
    </div>
  </section>

  <section class="pb-16">
    <div class="container-x">
      <div class="mx-auto max-w-[760px] rounded-[18px] border border-border-subtle p-7">
        <div class="flex items-start gap-5">
          <svg width="44" height="48" viewBox="0 0 44 48" fill="none" stroke="#111" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="mt-1 hidden shrink-0 sm:block">
            <path d="M6 4 L 6 44 L 38 44"/>
            <path d="M6 4 L 38 4"/>
            <path d="M38 4 L 38 44"/>
            <path d="M6 4 L 26 8 L 26 40 L 6 44"/>
            <circle cx="23" cy="24" r="0.9" fill="#111"/>
            <path d="M30 18 L 34 16" style="opacity: 0.5;"/>
            <path d="M30 24 L 35 24" style="opacity: 0.5;"/>
            <path d="M30 30 L 34 32" style="opacity: 0.5;"/>
          </svg>
          <div>
            <div class="eyebrow">early access</div>
            <p class="mt-2 text-fg-1" style="font-size: 16px; line-height: 1.55;">
              We're scaling capacity carefully so every team gets the support and reliability they need. If signups fill, you'll join the waitlist and get access as we open more spots.
            </p>
            <p class="mt-3 text-[14px] text-fg-2">
              Smaller group, hands-on support, fewer surprises. That's the trade we're making at this stage.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <ClosingCTA />
</PageLayout>
